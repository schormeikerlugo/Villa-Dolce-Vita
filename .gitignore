# build output
dist/
.output/

# dependencies
node_modules/

# astro
.astro/

# environment
.env
.env.production
.env*.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# macOS / editor
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/

# vercel
.vercel

# temp media (raw source lives in content/, converted output is committed)
*.mov.tmp

# Raw source material — NOT needed for the build (Astro uses src/assets + public).
# Heavy originals used only to (re)generate web assets via `npm run media`.
content/

# Reference material — heavy originals, not part of the build.
referencia/
