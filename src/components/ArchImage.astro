---
/**
 * ArchImage — the signature arched-frame photo used throughout the site
 * (see reference 01 / 04). Optionally parallaxes on scroll.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  parallax?: number | false;
  class?: string;
  widths?: number[];
  sizes?: string;
}
const {
  src,
  alt,
  parallax = false,
  class: className = "",
  widths = [480, 768, 1100, 1600],
  sizes = "(max-width: 768px) 90vw, 45vw",
} = Astro.props;
---

<figure class={`arch ${className}`} data-parallax-scope>
  <div class="arch__frame hoist">
    <div class="arch__media" data-parallax={parallax === false ? undefined : parallax}>
      <Image src={src} alt={alt} widths={widths} sizes={sizes} loading="lazy" />
    </div>
  </div>
</figure>

<style>
  .arch {
    margin: 0;
  }
  .arch__frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-arch);
    aspect-ratio: 3 / 4;
    box-shadow: var(--shadow-soft);
  }
  /* Extra vertical bleed so the parallax shift never exposes a gap inside the
     frame. The media travels via yPercent (relative to its OWN height): with
     strength ~0.12 and height 140%, that's ~0.12 * 140% = ~17% of the frame.
     A 20% bleed on each edge keeps the frame covered across the whole range. */
  .arch__media {
    position: absolute;
    inset: -20% 0;
    height: 140%;
  }
  .arch__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
