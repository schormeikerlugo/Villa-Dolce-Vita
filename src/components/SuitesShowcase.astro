---
/**
 * SuitesShowcase — a pinned horizontal suites carousel.
 *
 * Desktop: the section pins to the viewport and vertical scroll is translated
 * into horizontal travel of the track (GSAP ScrollTrigger + scrub). The card
 * nearest the centre becomes the protagonist — it grows large and reveals its
 * full caption + CTAs. The guest must scroll through every suite before the
 * page continues to the section below; scrolling up rewinds through them.
 *
 * Mobile / prefers-reduced-motion: no pin. The track is a plain, edge-to-edge
 * scroll-snap row and every card links to /suites#slug. Fully functional
 * without JS.
 */
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import Button from "./Button.astro";
import type { Suite } from "../data/suites";
import { bookingHref } from "../data/site";

interface Props {
  suites: Suite[];
  eyebrow?: string;
  title: string;
  subtitle?: string;
  allSuitesHref?: string;
}
const {
  suites,
  eyebrow = "The Suites",
  title,
  subtitle,
  allSuitesHref = "/suites",
} = Astro.props;

const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<section class="suites-showcase" data-suites-showcase data-no-reveal>
  <div class="suites-pin" data-suites-pin>
    <div class="suites-viewport">
      <div class="wrap suites-head-wrap">
        <div class="suites-head">
          <SectionHeader eyebrow={eyebrow} title={title} align="center">
            {subtitle && <p>{subtitle}</p>}
          </SectionHeader>
          <div class="suites-head__aside">
            <div class="carousel-nav" data-carousel-nav>
              <button type="button" class="carousel-nav__btn" data-carousel-prev aria-label="Previous suite">
                <span aria-hidden="true">←</span>
              </button>
              <button type="button" class="carousel-nav__btn" data-carousel-next aria-label="Next suite">
                <span aria-hidden="true">→</span>
              </button>
            </div>
            <Button href={allSuitesHref} variant="ghost" class="suites-head__cta">Explore all suites</Button>
          </div>
        </div>
      </div>

      <!-- TRACK — horizontal row of suite cards. -->
      <div class="carousel" data-carousel>
        <ol class="carousel__track" data-carousel-track role="list">
          {
            suites.map((s, i) => (
              <li
                class:list={["suitecard", { "is-active": i === 0 }]}
                data-card-index={i}
              >
                <a class="suitecard__link" href={`/suites#${s.slug}`} aria-label={`View the ${s.name}`}>
                  <figure class="suitecard__figure">
                    <Image
                      src={s.images[0]}
                      alt={s.imageAlt}
                      widths={[500, 800, 1100, 1500, 1900]}
                      sizes="(max-width: 720px) 82vw, (max-width: 1100px) 62vw, 56vw"
                      loading={i <= 1 ? "eager" : "lazy"}
                    />
                    <div class="suitecard__scrim" aria-hidden="true" />
                    {s.badge && <span class="suitecard__badge">{s.badge}</span>}
                  </figure>

                  <div class="suitecard__caption">
                    <span class="suitecard__num">{pad(i)}</span>
                    <p class="suitecard__meta">
                      Sleeps {s.sleeps} · from €{s.fromNight} <span>/ night</span>
                    </p>
                    <h3 class="suitecard__name">{s.name}</h3>
                    <p class="suitecard__tag">{s.tagline}</p>
                    <span class="suitecard__cta">
                      <span class="suitecard__view">View suite →</span>
                    </span>
                  </div>
                </a>
                <a class="suitecard__book" href={bookingHref} tabindex="-1">Book</a>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  .suites-showcase {
    position: relative;
    background: var(--c-ivory, #f3eee6);
    color: var(--text);
  }

  /* The pin wrapper. Its tall height (set by JS on desktop) provides the
     scroll distance that drives the horizontal travel. Default: content flow. */
  .suites-pin {
    position: relative;
  }
  .suites-viewport {
    display: flex;
    flex-direction: column;
    padding-block: var(--section-y);
    gap: var(--space-group);
  }
  /* When pinned, the viewport becomes a full-height sticky stage. */
  .suites-showcase.is-pinned .suites-viewport {
    height: 100vh;
    padding-block: clamp(2rem, 6vh, 4rem);
    justify-content: center;
    overflow: hidden;
  }

  .suites-head-wrap {
    flex: 0 0 auto;
  }
  .suites-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
    text-align: center;
  }
  .suites-head :global(.sechead) {
    margin-bottom: 0;
  }
  .suites-head :global(.sechead p) {
    max-width: 44ch;
  }
  .suites-head__aside {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    flex: 0 0 auto;
  }
  .suites-head__cta {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  /* ---- Carousel navigation buttons ---- */
  .carousel-nav {
    display: flex;
    gap: 0.6rem;
  }
  .carousel-nav__btn {
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--text);
    font-size: 1.05rem;
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }
  .carousel-nav__btn:hover {
    background: var(--accent);
    color: var(--c-forest);
    border-color: var(--accent);
  }
  .carousel-nav__btn:disabled {
    opacity: 0.32;
    cursor: default;
  }
  .carousel-nav__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ---- Carousel track ---- */
  .carousel {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    /* Fallback (no pin): native horizontal scroll-snap. */
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .carousel::-webkit-scrollbar {
    display: none;
  }
  /* When pinned, JS drives translateX — disable native scroll & snap. */
  .suites-showcase.is-pinned .carousel {
    overflow: visible;
    scroll-snap-type: none;
  }
  .carousel__track {
    list-style: none;
    margin: 0;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2vw, 2.4rem);
    padding: 0.6rem clamp(1.2rem, 50vw - 23rem, 50vw);
    will-change: transform;
  }
  .suites-showcase.is-pinned .carousel__track {
    /* Padding handled by JS offset; keep a small edge gutter. */
    padding: 0.6rem clamp(1.2rem, 4vw, 4rem);
  }

  /* ---- Suite card ---- */
  .suitecard {
    position: relative;
    flex: 0 0 auto;
    width: clamp(14rem, 22vw, 20rem);
    scroll-snap-align: center;
    transition:
      width var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out),
      opacity var(--dur) var(--ease-out);
    opacity: 0.5;
    transform: scale(0.92);
  }
  .suitecard.is-active {
    /* Larger protagonist. */
    width: clamp(22rem, 72vw, 74rem);
    opacity: 1;
    transform: scale(1);
  }
  .suitecard__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .suitecard__figure {
    position: relative;
    margin: 0;
    width: 100%;
    height: clamp(24rem, 62vh, 46rem);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .suitecard__figure :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .suitecard.is-active .suitecard__figure :global(img) {
    transform: scale(1.03);
  }
  .suitecard__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(38, 36, 31, 0) 30%,
      rgba(38, 36, 31, 0.35) 62%,
      rgba(38, 36, 31, 0.9) 100%
    );
    pointer-events: none;
  }
  .suitecard__badge {
    position: absolute;
    top: 1.1rem;
    left: 1.1rem;
    background: var(--accent);
    color: var(--c-forest);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.45rem 0.8rem;
    border-radius: var(--radius-sm);
    z-index: 3;
  }

  /* Caption over the bottom of the image. */
  .suitecard__caption {
    position: absolute;
    left: clamp(1.2rem, 2.2vw, 2.6rem);
    right: clamp(1.2rem, 2.2vw, 2.6rem);
    bottom: clamp(1.2rem, 2.2vw, 2.4rem);
    z-index: 2;
    color: var(--c-ivory);
    text-align: left;
    pointer-events: none;
  }
  .suitecard__num {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .suitecard__meta {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition:
      opacity var(--dur) var(--ease-out),
      max-height var(--dur) var(--ease-out);
  }
  .suitecard__meta span {
    color: var(--text-on-dark-muted);
  }
  .suitecard__name {
    font-size: clamp(1.4rem, 1rem + 1.8vw, 3.2rem);
    line-height: 1.03;
    margin-top: 0.2rem;
    transition: font-size var(--dur) var(--ease-out);
  }
  .suitecard__tag {
    font-size: 1rem;
    color: var(--text-on-dark-muted);
    margin-top: 0.3rem;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition:
      opacity var(--dur) var(--ease-out),
      max-height var(--dur) var(--ease-out);
  }
  .suitecard__cta {
    display: block;
    margin-top: 1.1rem;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition:
      opacity var(--dur) var(--ease-out),
      max-height var(--dur) var(--ease-out);
  }
  .suitecard__view {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-ivory);
    border-bottom: 1px solid rgba(243, 238, 230, 0.5);
    padding-bottom: 0.2rem;
    transition: color var(--dur-fast), border-color var(--dur-fast);
  }
  .suitecard__link:hover .suitecard__view {
    color: var(--accent);
    border-color: var(--accent);
  }
  .suitecard.is-active .suitecard__meta,
  .suitecard.is-active .suitecard__tag,
  .suitecard.is-active .suitecard__cta {
    opacity: 1;
    max-height: 6rem;
  }

  /* Book pill — top-right of the active card. */
  .suitecard__book {
    position: absolute;
    top: 1.1rem;
    right: 1.1rem;
    z-index: 4;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.55rem 1.2rem;
    border-radius: var(--radius-sm);
    background: var(--c-ivory);
    color: var(--c-charcoal);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition:
      background var(--dur-fast),
      color var(--dur-fast),
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .suitecard.is-active .suitecard__book {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .suitecard__book:hover {
    background: var(--accent);
    color: var(--c-forest);
  }
  .suitecard__book:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .suitecard,
    .suitecard__figure :global(img),
    .suitecard__book,
    .suitecard__meta,
    .suitecard__tag,
    .suitecard__cta {
      transition: none !important;
    }
    .carousel {
      scroll-behavior: auto;
    }
  }
</style>
