---
/**
 * Nav — fixed top navigation.
 * - Transparent over hero media; gains a solid backdrop once scrolled.
 * - `theme="light"` for pages without a dark hero.
 * - Compact grouped menu on desktop (dropdowns); slide-in panel on mobile.
 */
import { navGroups, bookingHref, site, type NavNode, type NavItem } from "../data/site";
import Button from "./Button.astro";

interface Props {
  theme?: "dark" | "light";
  [key: string]: unknown;
}
const { theme = "dark", ...rest } = Astro.props;
const current = Astro.url.pathname.replace(/\/$/, "") || "/";

const norm = (href: string) => href.replace(/\/$/, "") || "/";
const hasChildren = (n: NavNode): n is Extract<NavNode, { children: NavItem[] }> =>
  "children" in n && Array.isArray((n as { children?: unknown }).children);

/** A node is active if its own href matches, or any of its children match. */
function isActive(node: NavNode): boolean {
  if ("href" in node && node.href && norm(node.href) === current) return true;
  if (hasChildren(node)) return node.children.some((c) => norm(c.href) === current);
  return false;
}
---

<header class="nav" data-theme={theme} id="site-nav" {...rest}>
  <div class="nav__inner">
    <a class="nav__brand" href="/" aria-label={`${site.name} — home`}>
      <img src="/logo.svg" alt={site.name} width="150" height="45" />
    </a>

    <nav class="nav__menu" aria-label="Primary">
      <ul>
        {
          navGroups.map((node) => {
            const active = isActive(node);
            if (!hasChildren(node)) {
              return (
                <li>
                  <a href={node.href} class:list={["nav__link", { active }]}>
                    {node.label}
                  </a>
                </li>
              );
            }
            const groupHrefs = [node.href, ...node.children.map((c) => c.href)]
              .filter(Boolean)
              .map((h) => norm(h as string))
              .join(" ");
            return (
              <li class="nav__group">
                {node.href ? (
                  <a
                    href={node.href}
                    class:list={["nav__link", "nav__grouptrigger", { active }]}
                    aria-haspopup="true"
                    data-nav-group={groupHrefs}
                  >
                    {node.label}
                    <span class="nav__caret" aria-hidden="true" />
                  </a>
                ) : (
                  <button
                    type="button"
                    class:list={["nav__link", "nav__grouptrigger", { active }]}
                    aria-haspopup="true"
                    aria-expanded="false"
                    data-nav-group={groupHrefs}
                  >
                    {node.label}
                    <span class="nav__caret" aria-hidden="true" />
                  </button>
                )}
                <div class="nav__dropdown">
                  <ul>
                    {node.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={["nav__droplink", { active: norm(child.href) === current }]}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="nav__cta">
      <Button href={bookingHref} variant="secondary" onDark>Check Availability</Button>
    </div>

    <button class="nav__burger" aria-label="Open menu" aria-expanded="false" id="nav-burger">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile panel -->
  <div class="nav__panel" id="nav-panel">
    <ul class="nav__panel-list">
      {
        navGroups.map((node) =>
          !hasChildren(node) ? (
            <li>
              <a href={node.href} class="nav__panel-link">
                {node.label}
              </a>
            </li>
          ) : (
            <li class="nav__panel-group">
              {node.href ? (
                <a href={node.href} class="nav__panel-link nav__panel-grouphead">
                  {node.label}
                </a>
              ) : (
                <span class="nav__panel-link nav__panel-grouphead">{node.label}</span>
              )}
              <ul class="nav__panel-sub">
                {node.children.map((child) => (
                  <li>
                    <a href={child.href} class="nav__panel-sublink">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ),
        )
      }
    </ul>
    <Button href={bookingHref} variant="primary" class="nav__panel-cta">
      Check Availability
    </Button>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: var(--z-nav);
    color: var(--c-ivory);
    /* Space so the floating pill sits away from the very top edge. */
    padding: clamp(1rem, 2vw, 1.6rem) clamp(1rem, 3vw, 2.5rem) 0;
    transition: color var(--dur) var(--ease-out);
  }

  /* Intro entrance — applied on the home page only (via a class set in Hero).
     The pill drops in from above after the hero content has settled. */
  .nav.nav--intro .nav__inner {
    opacity: 0;
    transform: translateY(-24px);
    animation: nav-drop-in 0.8s var(--ease-out) 2s forwards;
  }
  @keyframes nav-drop-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav.nav--intro .nav__inner {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
  /* The bar itself is a floating, translucent rounded "pill". */
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: var(--content-max);
    margin-inline: auto;
    padding: 0.7rem 0.9rem 0.7rem clamp(1rem, 2vw, 1.6rem);
    border-radius: 999px;
    background: rgba(38, 36, 31, 0.26);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    border: 1px solid rgba(243, 238, 230, 0.14);
    box-shadow: 0 10px 40px -18px rgba(0, 0, 0, 0.5);
    transition:
      background var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }

  .nav__brand img {
    height: 44px;
    width: auto;
    /* Logo art is dark; invert to ivory while over hero. */
    filter: brightness(0) invert(1);
    transition: filter var(--dur) var(--ease-out);
  }

  .nav__menu ul {
    display: flex;
    gap: clamp(0.9rem, 1.4vw, 1.8rem);
  }
  .nav__link {
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.85;
    padding-bottom: 3px;
    border-bottom: 1px solid transparent;
    transition:
      opacity var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
    white-space: nowrap;
  }
  .nav__link:hover,
  .nav__link.active {
    opacity: 1;
    border-color: currentColor;
  }

  /* ---- Grouped dropdowns (desktop) ---- */
  .nav__group {
    position: relative;
  }
  .nav__grouptrigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    cursor: pointer;
    font: inherit;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: inherit;
  }
  .nav__caret {
    width: 5px;
    height: 5px;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    transition: transform var(--dur-fast) var(--ease-out);
    opacity: 0.8;
  }
  /* Dropdown panel — hidden until hover / keyboard focus within the group. */
  .nav__dropdown {
    position: absolute;
    top: calc(100% + 0.8rem);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    min-width: 13rem;
    padding: 0.6rem;
    background: rgba(47, 63, 53, 0.94);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    border: 1px solid rgba(243, 238, 230, 0.16);
    border-radius: 14px;
    box-shadow: 0 18px 44px -20px rgba(0, 0, 0, 0.6);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      visibility var(--dur-fast);
    z-index: 1;
  }
  /* A small hover bridge so the pointer can cross the gap without closing. */
  .nav__dropdown::before {
    content: "";
    position: absolute;
    top: -0.8rem;
    left: 0;
    right: 0;
    height: 0.8rem;
  }
  .nav__group:hover .nav__dropdown,
  .nav__group:focus-within .nav__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nav__group:hover .nav__caret,
  .nav__group:focus-within .nav__caret {
    transform: rotate(-135deg) translateY(2px);
  }
  .nav__dropdown ul {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .nav__droplink {
    display: block;
    padding: 0.6rem 0.9rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-ivory);
    border-radius: 8px;
    opacity: 0.85;
    white-space: nowrap;
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }
  .nav__droplink:hover,
  .nav__droplink.active {
    opacity: 1;
    color: var(--accent);
    background: rgba(243, 238, 230, 0.08);
  }

  /* Nav CTA — no outline, fully rounded (pill) hover. */
  .nav__cta :global(.btn) {
    --btn-border: transparent;
    --btn-bg: rgba(243, 238, 230, 0.1);
    border-radius: 999px;
  }
  .nav__cta :global(.btn:hover) {
    --btn-bg: var(--accent);
    --btn-fg: var(--c-cypress);
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
  }
  .nav__burger span {
    width: 24px;
    height: 1.5px;
    background: currentColor;
    transition: transform var(--dur-fast) var(--ease-out), opacity var(--dur-fast);
  }

  /* Scrolled / solid state (toggled via .is-solid) — pill gets more opaque. */
  .nav.is-solid .nav__inner {
    background: rgba(47, 63, 53, 0.92);
    border-color: rgba(243, 238, 230, 0.16);
    box-shadow: 0 14px 44px -20px rgba(0, 0, 0, 0.65);
  }

  /* Light theme pages (no dark hero) */
  .nav[data-theme="light"] {
    color: var(--c-charcoal);
  }
  .nav[data-theme="light"] .nav__inner {
    background: rgba(243, 238, 230, 0.85);
    border-color: var(--line);
  }
  .nav[data-theme="light"] .nav__brand img {
    filter: none;
  }

  /* Mobile panel — hidden by default, revealed via .is-open */
  .nav__panel {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-nav) + 1);
    background: var(--c-forest);
    color: var(--c-ivory);
    /* Hidden state */
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 5rem var(--gutter) 3rem;
  }
  .nav__panel.is-open {
    display: flex;
  }
  /* Grouped list — left-aligned like the reference sketch, not centered. */
  .nav__panel-list {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    width: min(22rem, 100%);
    text-align: left;
  }
  .nav__panel-link {
    font-family: var(--font-display);
    font-size: 1.7rem;
    line-height: 1.1;
  }
  /* Group heading + indented subitems with a vertical hairline (the sketch). */
  .nav__panel-group {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .nav__panel-grouphead {
    color: var(--c-ivory);
  }
  .nav__panel-sub {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-left: 0.9rem;
    padding-left: 1.1rem;
    border-left: 1px solid var(--line-on-dark);
  }
  .nav__panel-sublink {
    font-family: var(--font-body);
    font-size: 1rem;
    letter-spacing: 0.06em;
    color: var(--text-on-dark-muted);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav__panel-sublink:hover {
    color: var(--accent);
  }
  .nav__panel-cta {
    margin-top: 1.4rem;
  }

  @media (max-width: 1080px) {
    .nav__menu,
    .nav__cta {
      display: none;
    }
    .nav__burger {
      display: flex;
    }
  }
</style>

<script>
  // The nav persists across View Transitions (transition:persist), so bind its
  // listeners only once, and refresh per-page state on every navigation.
  function setupNav() {
    const navEl = document.getElementById("site-nav");
    const burger = document.getElementById("nav-burger");
    const panel = document.getElementById("nav-panel");
    if (!navEl || !burger || !panel) return;

    if (!navEl.dataset.bound) {
      navEl.dataset.bound = "true";

      // Solidify the nav once scrolled past the hero.
      const onScroll = () => {
        navEl.classList.toggle("is-solid", window.scrollY > window.innerHeight * 0.7);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Mobile panel toggle.
      let open = false;
      const toggle = (state: boolean) => {
        open = state;
        panel.classList.toggle("is-open", open);
        burger.setAttribute("aria-expanded", String(open));
        document.body.style.overflow = open ? "hidden" : "";
      };
      burger.addEventListener("click", () => toggle(!open));
      panel
        .querySelectorAll("a")
        .forEach((a) => a.addEventListener("click", () => toggle(false)));
    }

    // --- Per-page refresh (runs on first load and after each navigation) ---
    // 1) Theme: read the page's requested nav theme from the swapped-in meta.
    const themeMeta = document.querySelector<HTMLMetaElement>("[data-nav-theme]");
    if (themeMeta) navEl.setAttribute("data-theme", themeMeta.content);

    // 2) Active link: highlight the entry matching the current path.
    const current = location.pathname.replace(/\/$/, "") || "/";
    // Simple links (and group triggers that carry their own href).
    navEl.querySelectorAll<HTMLElement>(".nav__link").forEach((el) => {
      const group = el.dataset.navGroup;
      if (group !== undefined) {
        // Group trigger: active if the current path is the group's own page
        // OR any of its children's pages.
        const hrefs = group.split(/\s+/).filter(Boolean);
        el.classList.toggle("active", hrefs.includes(current));
      } else if (el instanceof HTMLAnchorElement) {
        const href = new URL(el.href).pathname.replace(/\/$/, "") || "/";
        el.classList.toggle("active", href === current);
      }
    });
    // Dropdown sublinks.
    navEl.querySelectorAll<HTMLAnchorElement>(".nav__droplink").forEach((a) => {
      const href = new URL(a.href).pathname.replace(/\/$/, "") || "/";
      a.classList.toggle("active", href === current);
    });

    // 3) Reset the solid state for the new page's scroll position.
    navEl.classList.toggle("is-solid", window.scrollY > window.innerHeight * 0.7);

    // 4) Close the mobile panel if it was open during navigation.
    panel.classList.remove("is-open");
    burger.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  document.addEventListener("astro:page-load", setupNav);
</script>
