---
/**
 * PageHero — compact hero for interior pages: a full-bleed image with an
 * overlaid title. Smaller than the homepage Hero, no feature bar.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  eyebrow?: string;
  title: string;
  image: ImageMetadata;
  imageAlt?: string;
}
const { eyebrow, title, image, imageAlt = "" } = Astro.props;
---

<section class="pagehero">
  <div class="pagehero__media">
    <Image
      src={image}
      alt={imageAlt}
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="pagehero__overlay" aria-hidden="true"></div>
  </div>
  <div class="pagehero__content wrap">
    {eyebrow && <p class="eyebrow eyebrow--gold">{eyebrow}</p>}
    <h1>{title}</h1>
  </div>
</section>

<style>
  .pagehero {
    position: relative;
    min-height: 68svh;
    display: flex;
    align-items: flex-end;
    color: var(--c-ivory);
    overflow: hidden;
  }
  .pagehero__media {
    position: absolute;
    inset: 0;
  }
  .pagehero__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pagehero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15, 42, 36, 0.4) 0%,
      rgba(15, 42, 36, 0.15) 45%,
      rgba(27, 30, 31, 0.7) 100%
    );
  }
  .pagehero__content {
    position: relative;
    z-index: 2;
    padding-bottom: clamp(3rem, 7vw, 6rem);
    padding-top: 8rem;
  }
  .pagehero__content h1 {
    max-width: 18ch;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4);
  }
  .pagehero__content .eyebrow {
    margin-bottom: 1rem;
  }
</style>
