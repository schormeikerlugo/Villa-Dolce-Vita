---
/**
 * PageHero — hero for interior pages: a full-bleed image with the eyebrow,
 * title and (optional) intro centred over it. The intro can be passed as the
 * `subtitle` prop or via the default slot for richer markup.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image: ImageMetadata;
  imageAlt?: string;
}
const { eyebrow, title, subtitle, image, imageAlt = "" } = Astro.props;
const hasSlot = Astro.slots.has("default");
---

<section class="pagehero">
  <div class="pagehero__media">
    <Image
      src={image}
      alt={imageAlt}
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="pagehero__overlay" aria-hidden="true"></div>
  </div>
  <div class="pagehero__content wrap">
    {eyebrow && (
      <p class="eyebrow eyebrow--gold pagehero__eyebrow">
        <span class="pagehero__diamond" aria-hidden="true"></span>{eyebrow}
      </p>
    )}
    <h1>{title}</h1>
    {subtitle && <p class="pagehero__sub">{subtitle}</p>}
    {hasSlot && (
      <div class="pagehero__sub">
        <slot />
      </div>
    )}
  </div>
</section>

<style>
  .pagehero {
    position: relative;
    min-height: 72svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--c-ivory);
    overflow: hidden;
  }
  .pagehero__media {
    position: absolute;
    inset: 0;
  }
  .pagehero__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pagehero__overlay {
    position: absolute;
    inset: 0;
    /* A touch stronger/centred so the centred copy stays legible. */
    background: radial-gradient(
        ellipse 90% 90% at 50% 50%,
        rgba(47, 63, 53, 0.42) 0%,
        rgba(47, 63, 53, 0.58) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(38, 36, 31, 0.5) 0%,
        rgba(47, 63, 53, 0.28) 45%,
        rgba(38, 36, 31, 0.62) 100%
      );
  }
  .pagehero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: clamp(6rem, 12vw, 9rem);
    /* Constrain the centred column. */
    max-width: 62rem;
  }
  .pagehero__content h1 {
    max-width: 20ch;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4);
  }
  .pagehero__content .eyebrow {
    margin-bottom: 1rem;
  }
  /* Small diamond ornament preceding the eyebrow — the "Geometry" motif. */
  .pagehero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    justify-content: center;
  }
  .pagehero__diamond {
    width: 7px;
    height: 7px;
    transform: rotate(45deg);
    border: 1px solid var(--accent);
    display: inline-block;
  }
  .pagehero__sub {
    margin-top: 1.6rem;
    margin-inline: auto;
    max-width: 56ch;
    text-align: center;
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.2rem);
    line-height: 1.6;
    color: rgba(243, 238, 230, 0.9);
    text-shadow: 0 1px 20px rgba(0, 0, 0, 0.35);
  }
  .pagehero__sub :global(p) {
    margin: 0;
  }
  .pagehero__sub :global(p + p) {
    margin-top: 0.9rem;
  }
</style>
