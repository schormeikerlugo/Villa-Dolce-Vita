---
/**
 * Hero — full-viewport cinematic opener (reference 01/02).
 * Background video + arched monogram frame + serif headline + scroll cue.
 * The six-icon FeatureBar now sits as its own strip just beneath the hero.
 */
import BackgroundVideo from "./BackgroundVideo.astro";
import type { videos } from "../data/media";
import { bookingHref } from "../data/site";

interface Props {
  eyebrow?: string;
  video: keyof typeof videos;
  /** Show the availability booking widget above the scroll cue. */
  booking?: boolean;
}
const { eyebrow, video, booking = false } = Astro.props;
---

<section class="hero">
  <BackgroundVideo video={video} />
  <div class="hero__fade" aria-hidden="true"></div>

  <div class="hero__content wrap">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__title">
      <slot name="title" />
    </h1>
    {Astro.slots.has("subtitle") && <p class="hero__sub"><slot name="subtitle" /></p>}
    {
      Astro.slots.has("actions") && (
        <div class="hero__actions">
          <slot name="actions" />
        </div>
      )
    }
  </div>

  {
    booking && (
      <form
        class="hero__booking"
        action={bookingHref}
        method="get"
        aria-label="Check availability"
      >
        <div class="bookbar__field">
          <label for="hero-dates">Choose a travel date</label>
          <input
            type="text"
            id="hero-dates"
            name="dates"
            value="May 12 — May 19, 2024"
            readonly
          />
          <svg
            class="bookbar__icon"
            viewBox="0 0 24 24"
            aria-hidden="true"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <rect x="3" y="4.5" width="18" height="16" rx="2" />
            <path d="M3 9h18M8 2.5v4M16 2.5v4" />
          </svg>
        </div>
        <button type="submit" class="bookbar__submit">
          Check Availability
        </button>
      </form>
    )
  }
</section>
<span id="after-hero"></span>

<script>
  // Trigger the nav's entrance choreography on pages that have a Hero (home).
  // Re-arms on every View-Transition navigation into a hero page.
  function armNavIntro() {
    const nav = document.getElementById("site-nav");
    const hero = document.querySelector(".hero");
    if (!nav || !hero) return;
    // Restart the CSS animation cleanly.
    nav.classList.remove("nav--intro");
    // Force reflow so re-adding the class replays the keyframes.
    void (nav as HTMLElement).offsetWidth;
    nav.classList.add("nav--intro");
  }
  document.addEventListener("astro:page-load", armNavIntro);
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    color: var(--c-ivory);
    overflow: hidden;
  }

  /* Gradient fade that melts the hero into the next (ivory) section below,
     replacing the hard-edged feature bar. */
  .hero__fade {
    position: absolute;
    inset: auto 0 0 0;
    height: clamp(9rem, 18vh, 15rem);
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(243, 238, 230, 0) 0%,
      rgba(243, 238, 230, 0.35) 55%,
      var(--bg) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin-inline: auto;
    padding-top: 27rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero__eyebrow {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.4rem;
    font-weight: 700;
  }
  .hero__title {
    font-size: clamp(3rem, 1.5rem + 8vw, 8rem);
    line-height: 0.98;
    font-weight: 500;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }
  .hero__title :global(em) {
    font-style: italic;
    color: var(--accent);
  }
  .hero__sub {
    margin-top: 1.6rem;
    max-width: 46ch;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
    font-weight: 700;
  }

  /* ── Entrance choreography ────────────────────────────────────────────
     1) Title rises up from below first.
     2) The surrounding content (eyebrow, subtitle, booking) follows a beat later.
     Order/timing is driven by animation-delay. */
  .hero__title {
    opacity: 0;
    transform: translateY(60px);
    animation: hero-rise 1.1s var(--ease-out) 0.2s forwards;
    /* Clip the descenders' overflow so the rise reads clean. */
    will-change: transform, opacity;
  }
  .hero__eyebrow,
  .hero__sub,
  .hero__actions {
    opacity: 0;
    transform: translateY(24px);
    animation: hero-rise 0.9s var(--ease-out) forwards;
  }
  /* "un segundo antes" → the content settles ~1s after the title starts. */
  .hero__eyebrow {
    animation-delay: 1.1s;
  }
  .hero__sub {
    animation-delay: 1.25s;
  }
  .hero__actions {
    animation-delay: 1.4s;
  }

  @keyframes hero-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero__actions {
    margin-top: 2.2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Booking widget — a translucent bar sitting low in the hero, above the cue. */
  .hero__booking {
    position: absolute;
    z-index: 3;
    left: 50%;
    bottom: clamp(6.5rem, 12vh, 8.5rem);
    transform: translateX(-50%);
    width: min(1180px, calc(100% - 2 * var(--gutter)));
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: stretch;
    gap: 0;
    background: rgba(27, 30, 31, 0.4);
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
    border: 1px solid rgba(247, 244, 238, 0.14);
    border-radius: 6px;
    box-shadow: 0 20px 60px -30px rgba(0, 0, 0, 0.7);
    overflow: hidden;
    /* Enters together with the hero content, just after the subtitle. */
    opacity: 0;
    transform: translateX(-50%) translateY(30px);
    animation: hero-booking-in 0.9s var(--ease-out) 1.55s forwards;
  }
  @keyframes hero-booking-in {
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  /* Respect reduced-motion: show everything immediately. */
  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__eyebrow,
    .hero__sub,
    .hero__actions,
    .hero__booking {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero__booking {
      transform: translateX(-50%);
    }
  }
  .bookbar__field {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    padding: 1rem 1.4rem;
    border-right: 1px solid rgba(247, 244, 238, 0.12);
    text-align: left;
  }
  .bookbar__field label {
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
  }
  .bookbar__field input,
  .bookbar__field select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    color: var(--c-ivory);
    font-family: var(--font-body);
    font-size: 0.98rem;
    padding: 0;
    padding-right: 1.6rem;
    cursor: pointer;
    width: 100%;
  }
  .bookbar__field input:focus,
  .bookbar__field select:focus {
    outline: none;
  }
  .bookbar__field select option {
    color: var(--c-charcoal);
  }
  .bookbar__icon {
    position: absolute;
    top: 50%;
    right: 1.2rem;
    transform: translateY(-30%);
    width: 20px;
    height: 20px;
    color: var(--text-on-dark-muted);
    pointer-events: none;
  }
  .bookbar__submit {
    padding: 1rem 2.2rem;
    background: var(--c-ivory);
    color: var(--c-charcoal);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out);
    white-space: nowrap;
  }
  .bookbar__submit:hover {
    background: var(--accent);
  }

  @media (max-width: 980px) {
    .hero__booking {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
    }
    .hero__content {
      padding-block: 9rem 3rem;
      min-height: 90svh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .hero__booking {
      position: static;
      transform: translateY(30px);
      width: min(560px, calc(100% - 2 * var(--gutter)));
      margin: -1rem auto 3rem;
      animation-name: hero-booking-in-static;
    }
  }
  @keyframes hero-booking-in-static {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (max-width: 560px) {
    .hero__booking {
      grid-template-columns: 1fr;
    }
    .bookbar__field {
      border-right: none;
      border-bottom: 1px solid rgba(247, 244, 238, 0.12);
    }
  }
</style>
