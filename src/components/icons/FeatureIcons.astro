---
/**
 * FeatureIcons — thin-line SVG icon set for the hero feature bar,
 * matching the refined line style in the brand references (01/02).
 * Pass `name` to render one icon.
 */
interface Props {
  name: "views" | "pool" | "sauna" | "dog" | "wine" | "leaf";
  class?: string;
}
const { name, class: className = "" } = Astro.props;
const s = { fill: "none", stroke: "currentColor", "stroke-width": "1.2", "stroke-linecap": "round", "stroke-linejoin": "round" };
---

<svg viewBox="0 0 48 48" class={className} aria-hidden="true" {...s}>
  {name === "views" && (
    <g>
      <path d="M6 34c5-8 9-11 12-11s6 3 10 8" />
      <path d="M20 31c4-6 7-8 10-8s7 4 12 11" />
      <circle cx="34" cy="15" r="4" />
      <path d="M4 40h40" />
    </g>
  )}
  {name === "pool" && (
    <g>
      <path d="M6 30c3 2 5 2 8 0s5-2 8 0 5 2 8 0 5-2 8 0" />
      <path d="M6 37c3 2 5 2 8 0s5-2 8 0 5 2 8 0 5-2 8 0" />
      <path d="M16 26V12a3 3 0 0 1 6 0" />
      <path d="M28 26V12a3 3 0 0 1 6 0" />
      <path d="M16 19h12" />
    </g>
  )}
  {name === "sauna" && (
    <g>
      <path d="M24 6c4 6 6 10 6 15a6 6 0 0 1-12 0c0-5 2-9 6-15Z" />
      <path d="M24 21c1.5 2 2 3.5 2 5a2 2 0 0 1-4 0c0-1.5.5-3 2-5Z" />
      <path d="M14 40h20" />
    </g>
  )}
  {name === "dog" && (
    <g>
      <path d="M12 20l-3-6 6 2h6l6-2-3 6" />
      <path d="M12 20v10a4 4 0 0 0 4 4h8a4 4 0 0 0 4-4V20" />
      <path d="M28 24l6-3v14" />
      <circle cx="17" cy="24" r="1" />
      <circle cx="23" cy="24" r="1" />
    </g>
  )}
  {name === "wine" && (
    <g>
      <circle cx="20" cy="16" r="3" />
      <circle cx="27" cy="13" r="3" />
      <circle cx="27" cy="20" r="3" />
      <circle cx="23" cy="23" r="3" />
      <path d="M24 26v14" />
      <path d="M18 40h12" />
    </g>
  )}
  {name === "leaf" && (
    <g>
      <path d="M24 40c0-14 6-24 16-30-2 16-8 24-16 26" />
      <path d="M24 40C24 28 18 20 8 16c1 12 6 20 16 22" />
      <path d="M24 40V22" />
    </g>
  )}
</svg>

<style>
  svg {
    width: 100%;
    height: 100%;
    color: var(--accent);
  }
</style>
