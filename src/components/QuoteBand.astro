---
/**
 * QuoteBand — a cinematic full-bleed image band with an overlaid pull-quote.
 * Breaks the section rhythm and adds editorial depth (see the homepage
 * "15 minutes to" band). Reusable across pages.
 *
 * Usage:
 *   <QuoteBand
 *     image={photos.hillsPinkDawn}
 *     imageAlt="Estate hills at first light"
 *     quote="It isn't quite a hotel and it isn't quite a farmhouse."
 *     cite="Linda & Frank, founders"
 *   />
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Reveal from "./Reveal.astro";

interface Props {
  image: ImageMetadata;
  imageAlt?: string;
  quote: string;
  cite?: string;
}
const { image, imageAlt = "", quote, cite } = Astro.props;
---

<section class="quoteband" data-parallax-scope>
  <div class="quoteband__media" data-parallax="0.14">
    <Image
      src={image}
      alt={imageAlt}
      widths={[768, 1100, 1440, 1920, 2560]}
      sizes="100vw"
      loading="lazy"
    />
  </div>
  <div class="quoteband__scrim" aria-hidden="true"></div>
  <div class="quoteband__inner wrap">
    <Reveal as="blockquote" class="quoteband__quote">{quote}</Reveal>
    {cite && <Reveal as="p" class="quoteband__cite" delay={0.1}>{cite}</Reveal>}
  </div>
</section>

<style>
  .quoteband {
    position: relative;
    width: 100%;
    min-height: 60svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: var(--c-ivory);
    text-align: center;
  }
  .quoteband__media {
    position: absolute;
    inset: -10% 0;
    height: 120%;
    z-index: 0;
  }
  .quoteband__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .quoteband__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse 75% 85% at 50% 50%,
      rgba(47, 63, 53, 0.74) 0%,
      rgba(47, 63, 53, 0.54) 55%,
      rgba(47, 63, 53, 0.32) 100%
    );
  }
  .quoteband__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-block: clamp(4rem, 9vw, 8rem);
  }
  .quoteband__quote {
    margin: 0;
    quotes: "\201C" "\201D";
    max-width: 22ch;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.9rem, 1.2rem + 3vw, 3.4rem);
    line-height: 1.25;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4);
  }
  .quoteband__quote::before {
    content: open-quote;
    color: var(--accent);
    margin-right: 0.05em;
  }
  .quoteband__quote::after {
    content: close-quote;
    color: var(--accent);
    margin-left: 0.05em;
  }
  .quoteband__cite {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent);
  }
</style>
