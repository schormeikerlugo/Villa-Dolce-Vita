  TikTok:
    "M16.5 3c.3 2.06 1.46 3.29 3.5 3.42v2.37c-1.18.12-2.2-.27-3.4-1v4.86c0 6.17-6.73 8.1-9.43 3.67-1.74-2.85-.67-7.85 4.92-8.05v2.5c-.43.07-.88.18-1.3.33-1.25.42-1.95 1.21-1.76 2.6.37 2.67 5.26 3.46 4.85-1.76V3h2.62Z",
  Pinterest:
    "M12 2.2a9.8 9.8 0 0 0-3.57 18.93c-.09-.8-.16-2.04.03-2.92.18-.77 1.15-4.9 1.15-4.9s-.29-.59-.29-1.46c0-1.37.79-2.39 1.78-2.39.84 0 1.25.63 1.25 1.39 0 .84-.54 2.1-.81 3.27-.23.98.49 1.78 1.46 1.78 1.75 0 3.1-1.85 3.1-4.51 0-2.36-1.7-4.01-4.12-4.01-2.8 0-4.45 2.1-4.45 4.28 0 .85.33 1.76.74 2.25.08.1.09.19.07.29-.08.31-.25 1-.28 1.14-.05.19-.15.23-.35.14-1.29-.6-2.1-2.48-2.1-3.99 0-3.25 2.36-6.23 6.8-6.23 3.57 0 6.35 2.55 6.35 5.95 0 3.55-2.24 6.4-5.34 6.4-1.04 0-2.02-.54-2.36-1.18l-.64 2.44c-.23.9-.86 2.02-1.28 2.71A9.8 9.8 0 1 0 12 2.2Z",
  Facebook:
    "M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.9h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94Z",
};

const services = nav.filter((n) =>
  ["/suites", "/experiences", "/weddings-events", "/dining"].includes(n.href),
);
const quick = nav.filter((n) =>
  ["/our-story", "/packages", "/journal", "/contact"].includes(n.href),
);
const suites = ["Napoli Suite", "Roma Suite", "Capri Suite", "Positano Suite", "Milano Suite"];
const year = new Date().getFullYear();
---

<footer class="footer bg-dark">
  <div class="footer__top wrap">
    <div class="footer__brand">
      <img src="/logo.svg" alt={site.name} width="200" height="60" />
      <p class="footer__tag">{site.tagline}</p>
      <address class="footer__contact">
        <a href={contact.whatsappHref}>WhatsApp: {contact.whatsapp}</a>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
        <span>{contact.address}</span>
      </address>

      <ul class="footer__social" aria-label="Follow us">
        {
          social.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
                  <path fill="currentColor" d={socialIcons[s.label]} />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <nav class="footer__col" aria-label="Experiences">
      <h3>Experiences</h3>
      <ul>
        {services.map((s) => <li><a href={s.href}>{s.label}</a></li>)}
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Explore">
      <h3>Explore</h3>
      <ul>
        {quick.map((q) => <li><a href={q.href}>{q.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer__col">
      <h3>Our Suites</h3>
      <ul>
        {suites.map((s) => <li><a href="/suites">{s}</a></li>)}
      </ul>
    </div>
  </div>

  <div class="footer__notices wrap">
    <p class="footer__notice"><strong>Disclaimer:</strong> {notices.alcohol}</p>
    <p class="footer__notice"><strong>A Note for Our Guests:</strong> {notices.animals}</p>
  </div>

  <div class="footer__bottom wrap">
    <p>© {year} {site.name}. All rights reserved.</p>
    <p>Massa Marittima, Tuscany · Italy</p>
  </div>
</footer>

<style>
  .footer {
    padding-top: clamp(3.5rem, 7vw, 6rem);
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--line-on-dark);
  }
  .footer__brand img {
    height: 56px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .footer__tag {
    margin-top: 0.75rem;
    font-size: var(--fs-small);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent);
  }
  .footer__contact {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-style: normal;
    font-size: 0.9rem;
    color: var(--text-on-dark-muted);
  }
  .footer__contact a:hover {
    color: var(--accent);
  }

  /* Social icon row. */
  .footer__social {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
  }
  .footer__social a {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1px solid var(--line-on-dark);
    color: var(--text-on-dark-muted);
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .footer__social a:hover {
    color: var(--c-forest);
    background: var(--accent);
    border-color: var(--accent);
  }
  .footer__social a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .footer__col h3 {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
    font-weight: 500;
  }
  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer__col a {
    font-size: 0.9rem;
    color: var(--text-on-dark-muted);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer__col a:hover {
    color: var(--c-ivory);
  }

  .footer__notices {
    padding-block: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem clamp(2rem, 5vw, 5rem);
    border-bottom: 1px solid var(--line-on-dark);
  }
  .footer__notices p {
    max-width: 100%;
    font-size: 0.78rem;
    line-height: 1.6;
    color: rgba(201, 196, 184, 0.75);
  }
  .footer__notices strong {
    color: var(--text-on-dark-muted);
    font-weight: 500;
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-block: 1.75rem;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: rgba(201, 196, 184, 0.7);
  }

  @media (max-width: 900px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 720px) {
    .footer__notices {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>
