---
/**
 * BackgroundVideo — full-bleed autoplaying, muted, looping background video
 * with a poster fallback. Sources come from data/media (webm + mp4).
 */
import { videoSources, type videos } from "../data/media";

interface Props {
  video: keyof typeof videos;
  class?: string;
  overlay?: boolean;
}
const { video, class: className = "", overlay = true } = Astro.props;
const { webm, mp4, poster } = videoSources(video);
---

<div class={`bgvideo ${className}`}>
  <video
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={poster}
    class="bgvideo__el"
  >
    <source src={webm} type="video/webm" />
    <source src={mp4} type="video/mp4" />
  </video>
  {overlay && <div class="bgvideo__overlay" aria-hidden="true"></div>}
</div>

<style>
  .bgvideo {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .bgvideo__el {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .bgvideo__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to bottom,
        rgba(47, 63, 53, 0.55) 0%,
        rgba(47, 63, 53, 0.2) 35%,
        rgba(38, 36, 31, 0.48) 100%
      );
  }
</style>
