---
/**
 * HomeGallery — a condensed 60/40 gallery teaser for the home page.
 *
 * Mirrors the look of the full /gallery page (rounded tiles, hover zoom,
 * caption-on-hover, soft shadow) but adapted to a home section:
 *   - Left column (≈60%): one oversized feature tile.
 *   - Right column (≈40%): a compact 2-up mosaic of the remaining tiles.
 *
 * The curated set is ~60% suite photos + ~40% /gallery photos (see index.astro),
 * and the section links out to the full /gallery archive.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionHeader from "./SectionHeader.astro";
import Button from "./Button.astro";

export interface HomeGalleryItem {
  image: ImageMetadata;
  alt: string;
  /** Short overlay caption shown on hover. */
  caption?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  /** First item is rendered as the large 60% feature tile. */
  items: HomeGalleryItem[];
  href?: string;
  cta?: string;
}

const {
  eyebrow = "Gallery",
  title,
  items,
  href = "/gallery",
  cta = "View full gallery",
} = Astro.props;

// The first two items fill the tall left column, stacked full-width so it
// doesn't read as one over-tall image; the rest form the right-hand mosaic.
const [featureA, featureB, ...rest] = items;
const features = [featureA, featureB].filter(Boolean);
---

<section class="section bg-ivory hgal">
  <div class="wrap">
    <SectionHeader eyebrow={eyebrow} title={title} align="center" />

    <div class="hgal__split">
      {/* 60% — two full-width feature tiles stacked vertically */}
      <div class="hgal__feature">
        {
          features.map((item, i) => (
            <figure
              class="hgal__tile hgal__tile--feature"
              data-reveal
              data-reveal-delay={0.05 + i * 0.05}
            >
              <Image
                src={item.image}
                alt={item.alt}
                widths={[640, 1000, 1600, 2000]}
                sizes="(max-width: 860px) 92vw, 55vw"
                loading="lazy"
              />
              {item.caption && (
                <figcaption class="hgal__caption">{item.caption}</figcaption>
              )}
            </figure>
          ))
        }
      </div>

      {/* 40% — mosaic of the remaining tiles */}
      <div class="hgal__mosaic">
        {
          rest.map((item, i) => (
            <figure
              class="hgal__tile"
              data-reveal
              data-reveal-delay={0.08 + i * 0.05}
            >
              <Image
                src={item.image}
                alt={item.alt}
                widths={[360, 560, 900]}
                sizes="(max-width: 860px) 46vw, 22vw"
                loading="lazy"
              />
              {item.caption && (
                <figcaption class="hgal__caption">{item.caption}</figcaption>
              )}
            </figure>
          ))
        }
      </div>
    </div>

    <div class="hgal__foot" data-reveal data-reveal-delay={0.1}>
      <Button href={href} variant="ghost">{cta}</Button>
    </div>
  </div>
</section>

<style>
  /* 60 / 40 split: two stacked feature tiles on the left, a uniform mosaic on
     the right. A shared row height keeps both columns perfectly even. */
  .hgal__split {
    --hgal-gap: 1rem;
    --hgal-row: 15.5rem; /* height of one mosaic row */
    display: grid;
    grid-template-columns: 60% 40%;
    gap: var(--hgal-gap);
    margin-top: var(--space-group);
  }

  /* Left column: two full-width feature tiles. Each spans two mosaic rows
     (plus the gap between them) so the pair lines up with the 4-row mosaic. */
  .hgal__feature {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: var(--hgal-gap);
    height: 100%;
  }

  /* Right column mosaic: fixed, uniform rows so every tile is the same size. */
  .hgal__mosaic {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: var(--hgal-row);
    gap: var(--hgal-gap);
    align-content: start;
  }

  /* Shared tile look — lifted from the /gallery page tiles. */
  .hgal__tile {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    cursor: pointer;
  }
  .hgal__tile :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }
  .hgal__tile:hover :global(img),
  .hgal__tile:focus-within :global(img) {
    transform: scale(1.04);
  }

  /* Each feature tile fills its half of the left column. */
  .hgal__tile--feature {
    height: 100%;
    min-height: 0;
  }

  .hgal__caption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 2.2rem 1rem 0.85rem;
    font-size: 0.8rem;
    line-height: 1.4;
    text-align: left;
    color: var(--c-ivory);
    background: linear-gradient(
      to top,
      rgba(18, 26, 22, 0.72),
      rgba(18, 26, 22, 0)
    );
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
    pointer-events: none;
  }
  .hgal__tile:hover .hgal__caption,
  .hgal__tile:focus-within .hgal__caption {
    opacity: 1;
    transform: translateY(0);
  }

  .hgal__foot {
    margin-top: 2.4rem;
    text-align: center;
  }

  /* Tablet: feature pair stacks above a 2-up mosaic. */
  @media (max-width: 860px) {
    .hgal__split {
      --hgal-row: 12rem;
      grid-template-columns: 1fr;
    }
    .hgal__feature {
      grid-template-rows: none;
      height: auto;
    }
    .hgal__tile--feature :global(img) {
      height: auto;
      min-height: 16rem;
      max-height: 22rem;
    }
  }
</style>
