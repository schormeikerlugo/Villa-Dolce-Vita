---
/**
 * Button — primary / secondary / ghost variants, straight from the brand guide.
 * Renders an <a> when `href` is given, otherwise a <button>.
 */
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  onDark?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = "primary",
  onDark = false,
  class: className = "",
  ...rest
} = Astro.props;

const Tag = href ? "a" : "button";
const classes = ["btn", `btn--${variant}`, onDark ? "btn--on-dark" : "", className]
  .filter(Boolean)
  .join(" ");
---

<Tag class={classes} href={href} {...rest}>
  <span class="btn__label"><slot /></span>
  {variant === "ghost" && <span class="btn__arrow" aria-hidden="true">→</span>}
</Tag>

<style>
  .btn {
    --btn-fg: var(--c-charcoal);
    --btn-bg: var(--accent);
    --btn-border: transparent;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.9rem;
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 500;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--btn-fg);
    background: var(--btn-bg);
    border: 1px solid var(--btn-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  /* Primary — filled gold */
  .btn--primary {
    --btn-bg: var(--accent);
    --btn-fg: var(--c-forest);
  }
  .btn--primary:hover {
    --btn-bg: var(--accent-deep);
    --btn-fg: var(--c-ivory);
  }

  /* Secondary — outlined */
  .btn--secondary {
    --btn-bg: transparent;
    --btn-fg: var(--c-charcoal);
    --btn-border: var(--c-charcoal);
  }
  .btn--secondary:hover {
    --btn-bg: var(--c-charcoal);
    --btn-fg: var(--c-ivory);
  }

  /* Ghost — text + arrow, underline reveal */
  .btn--ghost {
    --btn-bg: transparent;
    --btn-fg: var(--accent-deep);
    padding-inline: 0;
    border: 0;
    position: relative;
  }
  .btn--ghost .btn__label {
    position: relative;
  }
  .btn--ghost .btn__label::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(1);
    transform-origin: left;
    transition: transform var(--dur) var(--ease-out);
  }
  .btn--ghost:hover .btn__arrow {
    transform: translateX(4px);
  }
  .btn__arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  /* On dark surfaces */
  .btn--on-dark.btn--secondary {
    --btn-fg: var(--c-ivory);
    --btn-border: rgba(247, 244, 238, 0.55);
  }
  .btn--on-dark.btn--secondary:hover {
    --btn-bg: var(--c-ivory);
    --btn-fg: var(--c-forest);
  }
  .btn--on-dark.btn--ghost {
    --btn-fg: var(--accent);
  }
</style>
