---
/**
 * FeatureBar — the six-icon amenities strip beneath the hero
 * (see reference 01/02). Content matches content.md's feature set.
 */
import FeatureIcons from "./icons/FeatureIcons.astro";

const features = [
  { icon: "views", title: "Panoramic Views", copy: "Unrivaled vistas of Tuscany & the sea" },
  { icon: "pool", title: "Infinity Pool", copy: "Soak in beauty that never ends" },
  { icon: "sauna", title: "Sauna & Wellness", copy: "Rebalance body, mind & soul" },
  { icon: "dog", title: "Dogs Welcome", copy: "Because every guest is family" },
  { icon: "wine", title: "Wine & Dining", copy: "Local flavors, exceptionally paired" },
  { icon: "leaf", title: "Slow Living", copy: "Unplug. Unwind. Be present." },
] as const;
---

<ul class="features">
  {
    features.map((f) => (
      <li class="feature">
        <span class="feature__icon">
          <FeatureIcons name={f.icon} />
        </span>
        <span class="feature__title">{f.title}</span>
        <span class="feature__copy">{f.copy}</span>
      </li>
    ))
  }
</ul>

<style>
  .features {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    background: var(--bg-dark);
    border-top: 1px solid var(--line-on-dark);
  }
  .feature {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding: 1.6rem 1rem;
    color: var(--c-ivory);
    border-left: 1px solid var(--line-on-dark);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .feature:first-child {
    border-left: 0;
  }
  /* Accent line that grows up from the bottom on hover. */
  .feature::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    transform: translateX(-50%);
    transition: width var(--dur-fast) var(--ease-out);
  }
  .feature:hover {
    background: rgba(243, 238, 230, 0.05);
  }
  .feature:hover::after {
    width: 100%;
  }
  .feature__icon {
    width: 34px;
    height: 34px;
    margin-bottom: 0.3rem;
    color: var(--accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .feature:hover .feature__icon {
    transform: translateY(-4px) scale(1.08);
  }
  .feature__title {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .feature:hover .feature__title {
    color: var(--accent);
  }
  .feature__copy {
    font-size: 0.74rem;
    color: var(--text-on-dark-muted);
    line-height: 1.4;
    max-width: 16ch;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .feature:hover .feature__copy {
    color: var(--c-ivory);
  }

  @media (max-width: 900px) {
    .features {
      grid-template-columns: repeat(2, 1fr);
    }
    .feature:nth-child(odd) {
      border-left: 0;
    }
    .feature:nth-child(-n + 2) {
      border-top: 0;
    }
    .feature {
      border-top: 1px solid var(--line-on-dark);
    }
  }
</style>
