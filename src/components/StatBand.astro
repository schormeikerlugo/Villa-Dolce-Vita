---
/**
 * StatBand — a horizontal row of "estate by the numbers" figures.
 * Big display numerals with a gold eyebrow caption underneath.
 * Reusable across pages (About, Rooms, Experiences).
 *
 * Usage:
 *   <StatBand
 *     eyebrow="The Estate in Numbers"
 *     stats={[{ value: "40", label: "Acres of land" }, ...]}
 *     theme="dark"
 *   />
 */
import Reveal from "./Reveal.astro";

interface Stat {
  value: string;
  label: string;
  suffix?: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  stats: Stat[];
  theme?: "ivory" | "dark" | "stone";
}
const { eyebrow, title, stats, theme = "dark" } = Astro.props;
const bgClass = theme === "dark" ? "bg-dark" : theme === "stone" ? "statband--stone" : "bg-ivory";
---

<section class:list={["section", "statband", bgClass]}>
  <div class="wrap">
    {
      (eyebrow || title) && (
        <header class="statband__head">
          {eyebrow && <Reveal as="p" class="eyebrow eyebrow--gold">{eyebrow}</Reveal>}
          {title && <Reveal as="h2" delay={0.05}>{title}</Reveal>}
        </header>
      )
    }
    <ul class="statband__grid">
      {
        stats.map((s, i) => (
          <Reveal as="li" class="statband__item" delay={i * 0.08}>
            <span class="statband__value">
              {s.value}
              {s.suffix && <span class="statband__suffix">{s.suffix}</span>}
            </span>
            <span class="statband__label">{s.label}</span>
          </Reveal>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .statband--stone {
    background: var(--c-stone);
    color: var(--c-charcoal);
  }
  .statband__head {
    text-align: center;
    max-width: 46ch;
    margin-inline: auto;
    margin-bottom: var(--space-group);
  }
  .statband__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  /* NOTE: .statband__item is rendered by <Reveal as="li">, so it does NOT carry
     this component's scope hash — it must be targeted with :global(). */
  .statband__grid :global(.statband__item) {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    position: relative;
  }
  /* Hairline divider between stats (not before the first). */
  .statband__grid :global(.statband__item)::before {
    content: "";
    position: absolute;
    left: calc(-1 * clamp(0.75rem, 1.5vw, 1.5rem));
    top: 15%;
    bottom: 15%;
    width: 1px;
    background: var(--line-on-dark);
  }
  .bg-ivory .statband__grid :global(.statband__item)::before,
  .statband--stone .statband__grid :global(.statband__item)::before {
    background: var(--line);
  }
  .statband__grid :global(.statband__item):first-child::before {
    display: none;
  }
  .statband__value {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 1.8rem + 4vw, 5rem);
    line-height: 1;
    color: var(--accent);
    display: inline-flex;
    align-items: baseline;
    gap: 0.1em;
  }
  .bg-ivory .statband__value,
  .statband--stone .statband__value {
    color: var(--c-forest);
  }
  .statband__suffix {
    font-size: 0.45em;
    color: var(--accent);
  }
  .statband__label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
    max-width: 16ch;
  }
  .bg-ivory .statband__label,
  .statband--stone .statband__label {
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .statband__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(2rem, 5vw, 3rem);
    }
    /* Reset the divider for the 2-col layout; only show between columns. */
    .statband__item::before {
      display: none;
    }
  }
</style>
