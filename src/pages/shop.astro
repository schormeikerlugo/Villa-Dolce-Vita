---
/**
 * Shop — the estate boutique.
 * There is no live cart (no payment backend, and wine cannot currently be sold
 * per the alcohol notice). Each product offers an "Inquire" CTA that opens
 * WhatsApp pre-filled with the product name. See Docs/booking-and-shop.md.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Reveal from "../components/Reveal.astro";
import { Image } from "astro:assets";
import { photos } from "../data/media";
import { contact, notices } from "../data/site";
import { shopIntro, shopNote, productsByCategory } from "../data/shop";

const groups = productsByCategory();

/** Build a WhatsApp inquiry link pre-filled with the product name. */
const inquire = (name: string) => {
  const msg = "Hello Villa Dolce Vita, I'd like to enquire about the \"" + name + "\".";
  return contact.whatsappHref + "?text=" + encodeURIComponent(msg);
};
---

<BaseLayout
  title="Shop"
  description="A small selection of estate goods — olive oil, honey, table linens, bath amenities, apparel and gift baskets — made in small batches and available to take home or ship."
>
  <PageHero
    eyebrow="The Boutique"
    title="A Little of the Estate, to Take Home"
    image={photos.valdorciaGolden}
    imageAlt="Golden Tuscan hills, home of the estate goods"
  />

  <!-- INTRO -->
  <section class="section bg-ivory">
    <div class="wrap wrap--narrow" style="text-align:center">
      <Reveal as="p" delay={0.05} class="lead">{shopIntro}</Reveal>
      <Reveal as="p" delay={0.1} class="shop-note">{shopNote}</Reveal>
    </div>
  </section>

  <!-- CATEGORIES -->
  {
    groups.map((group, gi) => (
      <section class:list={["section", gi % 2 === 0 ? "bg-ivory" : "split--stone"]}>
        <div class="wrap">
          <SectionHeader eyebrow="Boutique" title={group.category} align="left" />
          <div class="shop-grid">
            {group.items.map((p) => (
              <article class="product card" data-reveal>
                <div class="product__media hoist">
                  <Image
                    src={p.image}
                    alt={p.imageAlt}
                    widths={[400, 640, 900]}
                    sizes="(max-width: 900px) 92vw, 30vw"
                    loading="lazy"
                  />
                  {p.badge && <span class="product__badge">{p.badge}</span>}
                </div>
                <div class="product__body">
                  <h3 class="product__name">{p.name}</h3>
                  <p class="product__blurb">{p.blurb}</p>
                  <div class="product__foot">
                    <span class="product__price">
                      {p.inquireOnly ? "Enquire for price" : p.price}
                    </span>
                    <a class="product__cta" href={inquire(p.name)} target="_blank" rel="noopener">
                      Inquire →
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <!-- ALCOHOL NOTICE (applies to wine/cellar items) -->
  <section class="section bg-dark">
    <div class="wrap wrap--narrow" style="text-align:center">
      <Reveal as="p" class="eyebrow eyebrow--gold">Please Note</Reveal>
      <Reveal as="p" delay={0.05} class="legal">{notices.alcohol}</Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 0.9rem + 1.2vw, 1.8rem);
    line-height: 1.5;
    color: var(--c-forest);
  }
  .shop-note {
    color: var(--text-muted);
    margin-top: 1.2rem;
    max-width: 56ch;
    margin-inline: auto;
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 2.5vw, 2.2rem);
  }
  /* Base look (border, radius, background, hover lift) comes from .card;
     image zoom on hover comes from .hoist. */
  .product__media {
    position: relative;
    aspect-ratio: 4 / 5;
  }
  .product__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--accent);
    color: var(--c-forest);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35rem 0.6rem;
    border-radius: var(--radius-sm);
  }
  .product__body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .product__name {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }
  .product__blurb {
    color: var(--text-muted);
    font-size: 0.9rem;
    flex: 1;
  }
  .product__foot {
    margin-top: 1.3rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .product__price {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--c-forest);
  }
  .product__cta {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    white-space: nowrap;
    transition: transform var(--dur-fast), color var(--dur-fast);
  }
  .product__cta:hover {
    color: var(--text);
    transform: translateX(3px);
  }

  .legal {
    color: var(--text-on-dark-muted);
    font-size: 0.95rem;
    max-width: 62ch;
    margin-inline: auto;
    margin-top: 1rem;
  }

  @media (max-width: 1000px) {
    .shop-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .shop-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
