---
/**
 * Rooms — the five suites in detail.
 * Each suite is an alternating editorial SplitSection with its feature list,
 * anchored by slug (e.g. /rooms#roma) so cards elsewhere can deep-link.
 * Content from suites.ts (lifted verbatim from content.md).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";
import { Image } from "astro:assets";
import { suites, roomsIntro } from "../data/suites";
import { photos, mockups } from "../data/media";
import { bookingHref } from "../data/site";

// The premium (highest-rate) suite gets a "Signature" flag.
const premiumSlug = [...suites].sort((a, b) => b.fromNight - a.fromNight)[0].slug;
---

<BaseLayout
  title="Rooms"
  description="Five private suites — Napoli, Roma, Capri, Positano and Milano — curated for real rest, with king- and queen-size beds, heated floors and panoramic Tuscan views."
>
  <PageHero
    eyebrow="The Suites"
    title="Five Rooms, One Unforgettable View"
    image={photos.terraceTableView}
    imageAlt="Private terrace overlooking the Tuscan valley"
  />

  <!-- INTRO -->
  <section class="section bg-ivory rooms-intro">
    <div class="wrap wrap--narrow" style="text-align:center">
      <Reveal as="p" class="eyebrow">Sophisticated Comfort</Reveal>
      <Reveal as="p" delay={0.05} class="lead">{roomsIntro}</Reveal>
    </div>
  </section>

  <!-- SUITES -->
  {
    suites.map((suite, i) => (
      <section
        id={suite.slug}
        class:list={["section", "suite-detail", i % 2 === 0 ? "bg-ivory" : "split--stone"]}
      >
        <div class:list={["suite-detail__inner", "wrap", { "is-reverse": i % 2 === 1 }]}>
          <div class="suite-detail__media" data-parallax-scope>
            <div class="suite-gallery" data-suite-gallery>
              <div class="suite-detail__img hoist">
                {suite.images.map((img, gi) => (
                  <Image
                    src={img}
                    alt={gi === 0 ? suite.imageAlt : `${suite.name} — view ${gi + 1}`}
                    widths={[560, 900, 1300, 1800]}
                    sizes="(max-width: 900px) 92vw, 56vw"
                    loading={gi === 0 ? "eager" : "lazy"}
                    class:list={["suite-gallery__slide", { "is-active": gi === 0 }]}
                    data-slide={gi}
                  />
                ))}
                {suite.badge && <span class="suite-detail__badge">{suite.badge}</span>}
                {suite.images.length > 1 && (
                  <>
                    <button
                      type="button"
                      class="suite-gallery__nav suite-gallery__nav--prev"
                      data-prev
                      aria-label={`Previous photo of the ${suite.name}`}
                    >
                      ‹
                    </button>
                    <button
                      type="button"
                      class="suite-gallery__nav suite-gallery__nav--next"
                      data-next
                      aria-label={`Next photo of the ${suite.name}`}
                    >
                      ›
                    </button>
                    <span class="suite-gallery__count" data-count>
                      1 / {suite.images.length}
                    </span>
                  </>
                )}
              </div>

              {suite.images.length > 1 && (
                <div class="suite-gallery__thumbs" role="tablist" aria-label={`${suite.name} photos`}>
                  {suite.images.map((img, gi) => (
                    <button
                      type="button"
                      class:list={["suite-gallery__thumb", { "is-active": gi === 0 }]}
                      data-thumb={gi}
                      role="tab"
                      aria-selected={gi === 0 ? "true" : "false"}
                      aria-label={`Show photo ${gi + 1} of the ${suite.name}`}
                    >
                      <Image
                        src={img}
                        alt=""
                        widths={[120, 200]}
                        sizes="120px"
                        loading="lazy"
                      />
                    </button>
                  ))}
                </div>
              )}
            </div>
          </div>

          <div class="suite-detail__copy">
            <Reveal as="p" class="eyebrow">
              {suite.slug === premiumSlug ? "Signature Suite · Sleeps " + suite.sleeps : "Sleeps " + suite.sleeps}
            </Reveal>
            <Reveal as="h2" delay={0.05}>{suite.name}</Reveal>
            <Reveal delay={0.08}>
              <p class="suite-detail__tagline">{suite.tagline}</p>
            </Reveal>
            <Reveal delay={0.1}><hr class="rule" /></Reveal>
            <Reveal delay={0.12}>
              <p class="suite-detail__intro">{suite.intro}</p>
            </Reveal>
            <Reveal delay={0.15}>
              <ul class="suite-detail__features">
                {suite.features.map((f) => (
                  <li>{f}</li>
                ))}
              </ul>
            </Reveal>
            <Reveal delay={0.18}>
              <div class="suite-detail__foot">
                <p class="suite-detail__from">
                  from <strong>€{suite.fromNight}</strong> / night
                </p>
                <Button href={bookingHref} variant="primary">
                  Check Availability
                </Button>
              </div>
            </Reveal>
          </div>
        </div>
      </section>
    ))
  }

  <!-- IN EVERY SUITE (branding detail) -->
  <section class="section bg-dark in-suite">
    <div class="wrap in-suite__inner">
      <div class="in-suite__copy">
        <Reveal as="p" class="eyebrow eyebrow--gold">In Every Suite</Reveal>
        <Reveal as="h2" delay={0.05}>The Little Things, Handled</Reveal>
        <Reveal delay={0.1}><hr class="rule" /></Reveal>
        <Reveal delay={0.12}>
          <p style="color:var(--text-on-dark-muted)">
            A handwritten welcome note and your room key waiting on arrival. Honey, olives and
            citrus from the farm. New bedding and adjustable pillows. A WhatsApp concierge on
            hand throughout your stay — and an optional butler service for those who'd like to be
            looked after completely.
          </p>
        </Reveal>
      </div>
      <Reveal as="div" class="in-suite__media hoist" delay={0.1}>
        <Image
          src={mockups.welcomeLetter}
          alt="Villa Dolce Vita welcome letter and room key in a suite"
          widths={[480, 768, 1100]}
          sizes="(max-width: 900px) 92vw, 44vw"
          loading="lazy"
        />
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 0.9rem + 1.2vw, 1.8rem);
    line-height: 1.5;
    color: var(--c-forest);
  }

  .suite-detail__inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2.5rem, 6vw, 6.5rem);
    align-items: center;
  }
  .suite-detail__inner.is-reverse .suite-detail__media {
    order: 2;
  }
  .suite-detail__img {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 5 / 6;
    box-shadow: var(--shadow-soft);
  }
  @media (min-width: 1100px) {
    .suite-detail__img {
      aspect-ratio: 4 / 5;
    }
  }

  /* ---- Gallery ---- */
  .suite-gallery__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity var(--dur-med, 0.5s) var(--ease-out, ease);
    pointer-events: none;
  }
  .suite-gallery__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  /* First slide stays visible before hydration / with JS off. */
  .suite-detail__img :global(img.suite-gallery__slide:first-of-type) {
    opacity: 1;
  }

  .suite-gallery__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.82);
    color: var(--c-forest, #1e3a2f);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--dur-fast, 0.25s), background var(--dur-fast, 0.25s);
    z-index: 2;
    backdrop-filter: blur(2px);
  }
  .suite-gallery__nav--prev { left: 0.8rem; }
  .suite-gallery__nav--next { right: 0.8rem; }
  .suite-detail__img:hover .suite-gallery__nav,
  .suite-gallery__nav:focus-visible {
    opacity: 1;
  }
  .suite-gallery__nav:hover {
    background: #fff;
  }

  .suite-gallery__count {
    position: absolute;
    bottom: 0.9rem;
    right: 0.9rem;
    z-index: 2;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
    background: rgba(20, 20, 20, 0.55);
    color: #fff;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .suite-gallery__thumbs {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.8rem;
    overflow-x: auto;
    scrollbar-width: thin;
    padding-bottom: 0.2rem;
  }
  .suite-gallery__thumb {
    flex: 0 0 auto;
    width: 4.5rem;
    aspect-ratio: 4 / 3;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    background: none;
    opacity: 0.6;
    transition: opacity var(--dur-fast, 0.25s), border-color var(--dur-fast, 0.25s);
  }
  .suite-gallery__thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .suite-gallery__thumb:hover {
    opacity: 0.85;
  }
  .suite-gallery__thumb.is-active {
    opacity: 1;
    border-color: var(--accent-deep, #c47a5a);
  }

  @media (prefers-reduced-motion: reduce) {
    .suite-gallery__slide {
      transition: none;
    }
  }

  .suite-detail__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--accent);
    color: var(--c-forest);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-sm);
  }
  .suite-detail__tagline {
    color: var(--accent-deep);
    font-size: 1.05rem;
    margin-top: 0.4rem;
  }
  .suite-detail__intro {
    color: var(--text-muted);
  }
  .suite-detail__features {
    list-style: none;
    margin: 1.6rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }
  .suite-detail__features li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--text-muted);
  }
  .suite-detail__features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    border: 1px solid var(--accent-deep);
    transform: rotate(45deg);
  }
  .suite-detail__foot {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .suite-detail__from {
    font-size: 0.95rem;
    color: var(--text-muted);
  }
  .suite-detail__from strong {
    color: var(--text);
    font-size: 1.2rem;
    font-family: var(--font-display);
  }

  .in-suite__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .in-suite__media {
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    aspect-ratio: 4 / 5;
  }
  .in-suite__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .suite-detail__inner,
    .in-suite__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .suite-detail__inner.is-reverse .suite-detail__media {
      order: 0;
    }
  }
</style>

<script>
  // Per-suite photo gallery: thumbnails + prev/next arrows crossfade slides.
  // Runs on load and after Astro view transitions (astro:page-load).
  function initSuiteGalleries() {
    const galleries = document.querySelectorAll<HTMLElement>("[data-suite-gallery]");
    galleries.forEach((gallery) => {
      if (gallery.dataset.galleryReady === "1") return;
      gallery.dataset.galleryReady = "1";

      const slides = Array.from(
        gallery.querySelectorAll<HTMLImageElement>(".suite-gallery__slide"),
      );
      const thumbs = Array.from(
        gallery.querySelectorAll<HTMLButtonElement>("[data-thumb]"),
      );
      const count = gallery.querySelector<HTMLElement>("[data-count]");
      const prev = gallery.querySelector<HTMLButtonElement>("[data-prev]");
      const next = gallery.querySelector<HTMLButtonElement>("[data-next]");
      if (slides.length < 2) return;

      let current = 0;
      const show = (i: number) => {
        current = (i + slides.length) % slides.length;
        slides.forEach((s, si) => s.classList.toggle("is-active", si === current));
        thumbs.forEach((t, ti) => {
          const on = ti === current;
          t.classList.toggle("is-active", on);
          t.setAttribute("aria-selected", on ? "true" : "false");
        });
        if (count) count.textContent = `${current + 1} / ${slides.length}`;
      };

      thumbs.forEach((t, ti) => t.addEventListener("click", () => show(ti)));
      prev?.addEventListener("click", () => show(current - 1));
      next?.addEventListener("click", () => show(current + 1));
    });
  }

  document.addEventListener("astro:page-load", initSuiteGalleries);
  initSuiteGalleries();
</script>
