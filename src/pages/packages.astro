---
/**
 * Packages & Rates — nightly rates, experience packages, wedding tiers.
 * All data from packages.ts (content.md). Rates are starting points to be
 * confirmed with ownership (see Docs).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";
import { photos } from "../data/media";
import { bookingHref } from "../data/site";
import {
  packagesIntro,
  rateColumns,
  rates,
  packages,
  weddingTiers,
  weddingTiersNote,
} from "../data/packages";
---

<BaseLayout
  title="Packages & Rates"
  description="Nightly rates by suite and season, bundled experience packages from Rest & Reset to Honeymoon, and three wedding tiers for up to 100 guests."
>
  <PageHero
    eyebrow="Packages & Rates"
    title="A Clear Price, Not a Menu of Add-Ons"
    subtitle={packagesIntro}
    image={photos.valdorciaMist}
    imageAlt="Misty Tuscan hills at dawn"
  />

  <!-- NIGHTLY RATES -->
  <section class="section split--stone">
    <div class="wrap">
      <SectionHeader eyebrow="Nightly Rates by Suite" title="What a Night Costs, by Season" align="left" />
      <div class="rate-scroll">
        <table class="rate-table">
          <thead>
            <tr>
              <th>Suite</th>
              <th>{rateColumns.low}</th>
              <th>{rateColumns.shoulder}</th>
              <th>{rateColumns.peak}</th>
            </tr>
          </thead>
          <tbody>
            {
              rates.map((r) => (
                <tr>
                  <td class="rate-suite">{r.suite}</td>
                  <td>{r.low}</td>
                  <td>{r.shoulder}</td>
                  <td class="rate-peak">{r.peak}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE PACKAGES -->
  <section class="section bg-ivory">
    <div class="wrap">
      <SectionHeader eyebrow="Experience Packages" title="Bundled, Named, Priced" align="center">
        <p>Five ways to spend your stay, each built around a different rhythm.</p>
      </SectionHeader>
      <div class="pkg-grid">
        {
          packages.map((p) => (
            <article class="pkg card" data-reveal>
              <div class="pkg__head">
                <p class="pkg__it">{p.italian}</p>
                <h3 class="pkg__name">{p.name}</h3>
                <p class="pkg__nights">{p.nights}</p>
              </div>
              <ul class="pkg__includes">
                {p.includes.map((it) => <li>{it}</li>)}
              </ul>
              <p class="pkg__price">{p.price}</p>
              <Button href={bookingHref} variant="ghost">Enquire</Button>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- WEDDING TIERS -->
  <section class="section bg-dark">
    <div class="wrap">
      <SectionHeader eyebrow="Wedding Tiers" title="Three Ways to Celebrate" align="center" onDark>
        <p style="color:var(--text-on-dark-muted)">{weddingTiersNote}</p>
      </SectionHeader>
      <div class="tiers">
        {
          weddingTiers.map((t, i) => (
            <article class:list={["tier", { "tier--mid": i === 1 }]} data-reveal>
              <h3 class="tier__name">{t.tier}</h3>
              <p class="tier__guests">{t.guests} guests</p>
              <hr class="rule" />
              <p class="tier__inc">{t.includes}</p>
            </article>
          ))
        }
      </div>
      <div class="center-cta">
        <Button href="/contact" variant="secondary" onDark>Request a Wedding Quote</Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-ivory">
    <div class="wrap wrap--narrow" style="text-align:center">
      <SectionHeader eyebrow="Book Direct" title="The Best Rate Is Always Here" align="center">
        <p>Reserve directly with us — no third parties, no markup.</p>
      </SectionHeader>
      <Reveal delay={0.15}>
        <Button href={bookingHref} variant="primary">Check Availability</Button>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 0.9rem + 1.2vw, 1.8rem);
    line-height: 1.5;
    color: var(--c-forest);
  }

  .rate-scroll {
    overflow-x: auto;
  }
  .rate-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
  }
  .rate-table th,
  .rate-table td {
    text-align: left;
    padding: 1rem 1rem;
    border-bottom: 1px solid var(--line);
  }
  .rate-table th {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    font-size: var(--fs-eyebrow);
    color: var(--accent-deep);
  }
  .rate-table td {
    font-family: var(--font-display);
    font-size: 1.15rem;
  }
  .rate-suite {
    font-family: var(--font-body) !important;
    font-size: 0.95rem !important;
    max-width: 22ch;
  }
  .rate-peak {
    color: var(--accent-deep);
  }

  /* Packages */
  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 2.5vw, 2.2rem);
  }
  /* Base look (border, radius, background, hover lift) comes from .card */
  .pkg {
    padding: 1.8rem 1.8rem 2rem;
  }
  .pkg__it {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--accent-deep);
    font-size: 1.1rem;
  }
  .pkg__name {
    font-size: 1.5rem;
    margin: 0.2rem 0;
  }
  .pkg__nights {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.2rem;
  }
  .pkg__includes {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    gap: 0.55rem;
    flex: 1;
  }
  .pkg__includes li {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.92rem;
    color: var(--text-muted);
  }
  .pkg__includes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 7px;
    height: 7px;
    border: 1px solid var(--accent-deep);
    transform: rotate(45deg);
  }
  .pkg__price {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--c-forest);
    margin-bottom: 1.2rem;
  }

  /* Wedding tiers */
  .tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 2.5vw, 2.2rem);
  }
  .tier {
    border: 1px solid var(--line-on-dark);
    border-radius: var(--radius);
    padding: 2rem 1.8rem;
    background: rgba(243, 238, 230, 0.04);
  }
  .tier--mid {
    border-color: var(--accent);
    background: rgba(196, 122, 90, 0.1); /* terracotta tint on the featured tier */
  }
  .tier__name {
    font-size: 1.7rem;
    color: var(--accent);
  }
  .tier__guests {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
    margin-top: 0.3rem;
  }
  .tier .rule {
    margin: 1.2rem 0;
  }
  .tier__inc {
    color: var(--text-on-dark-muted);
    font-size: 0.95rem;
  }
  .center-cta {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  @media (max-width: 1000px) {
    .pkg-grid,
    .tiers {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 620px) {
    .pkg-grid,
    .tiers {
      grid-template-columns: 1fr;
    }
  }
</style>
