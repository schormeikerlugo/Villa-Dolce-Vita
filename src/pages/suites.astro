---
/**
 * Suites — the five suites in detail.
 * Each suite is an alternating editorial SplitSection with its feature list,
 * anchored by slug (e.g. /suites#roma) so cards elsewhere can deep-link.
 * Content from suites.ts (lifted verbatim from content.md).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";
import { Image } from "astro:assets";
import { suites, roomsIntro } from "../data/suites";
import { photos, mockups } from "../data/media";
import { bookingHref, contact } from "../data/site";
import { galleryItems } from "../data/gallery";

// The premium (highest-rate) suite gets a "Signature" flag.
const premiumSlug = [...suites].sort((a, b) => b.fromNight - a.fromNight)[0].slug;

// Rate range for the closing CTA.
const lowestRate = Math.min(...suites.map((s) => s.fromNight));

// Evocative full-bleed background for the closing CTA.
const ctaImage = galleryItems.find((i) => i.slug === "villa-aerial-dusk")!.image;
---

<BaseLayout
  title="Suites"
  description="Five private suites — Napoli, Roma, Capri, Positano and Milano — curated for real rest, with king- and queen-size beds, heated floors and panoramic Tuscan views."
>
  <PageHero
    eyebrow="The Suites"
    title="Five Suites, One Unforgettable View"
    subtitle={roomsIntro}
    image={photos.terraceTableView}
    imageAlt="Private terrace overlooking the Tuscan valley"
  />

  <!-- SUITES -->
  {
    suites.map((suite, i) => (
      <>
      <section
        id={suite.slug}
        class:list={["section", "suite-detail", i % 2 === 0 ? "bg-ivory" : "split--stone"]}
      >
        <div class:list={["suite-detail__inner", "wrap", { "is-reverse": i % 2 === 1 }]}>
          <div class="suite-detail__media" data-parallax-scope>
            <div class="suite-gallery" data-suite-gallery>
              <div class="suite-detail__img hoist">
                {suite.images.map((img, gi) => (
                  <Image
                    src={img}
                    alt={gi === 0 ? suite.imageAlt : `${suite.name} — view ${gi + 1}`}
                    widths={[560, 900, 1300, 1800]}
                    sizes="(max-width: 900px) 92vw, 56vw"
                    loading={gi === 0 ? "eager" : "lazy"}
                    class:list={["suite-gallery__slide", { "is-active": gi === 0 }]}
                    data-slide={gi}
                  />
                ))}
                {suite.badge && <span class="suite-detail__badge">{suite.badge}</span>}
                {suite.images.length > 1 && (
                  <>
                    <button
                      type="button"
                      class="suite-gallery__nav suite-gallery__nav--prev"
                      data-prev
                      aria-label={`Previous photo of the ${suite.name}`}
                    >
                      ‹
                    </button>
                    <button
                      type="button"
                      class="suite-gallery__nav suite-gallery__nav--next"
                      data-next
                      aria-label={`Next photo of the ${suite.name}`}
                    >
                      ›
                    </button>
                    <span class="suite-gallery__count" data-count>
                      1 / {suite.images.length}
                    </span>
                  </>
                )}
              </div>

              {suite.images.length > 1 && (
                <div class="suite-gallery__thumbs" role="tablist" aria-label={`${suite.name} photos`}>
                  {suite.images.map((img, gi) => (
                    <button
                      type="button"
                      class:list={["suite-gallery__thumb", { "is-active": gi === 0 }]}
                      data-thumb={gi}
                      role="tab"
                      aria-selected={gi === 0 ? "true" : "false"}
                      aria-label={`Show photo ${gi + 1} of the ${suite.name}`}
                    >
                      <Image
                        src={img}
                        alt=""
                        widths={[120, 200]}
                        sizes="120px"
                        loading="lazy"
                      />
                    </button>
                  ))}
                </div>
              )}
            </div>
          </div>

          <div class="suite-detail__copy">
            <span class="suite-detail__num" aria-hidden="true">
              {String(i + 1).padStart(2, "0")}
            </span>
            <Reveal as="p" class="eyebrow suite-detail__kicker">
              {suite.slug === premiumSlug ? "Signature Suite · Sleeps " + suite.sleeps : "Sleeps " + suite.sleeps}
            </Reveal>
            <Reveal as="h2" delay={0.05}>{suite.name}</Reveal>
            <Reveal delay={0.08}>
              <p class="suite-detail__tagline">{suite.tagline}</p>
            </Reveal>
            <Reveal delay={0.1}>
              <p class="suite-detail__from">
                <span class="suite-detail__from-label">from</span>
                <strong>€{suite.fromNight}</strong>
                <span class="suite-detail__from-unit">/ night</span>
              </p>
            </Reveal>
            <Reveal delay={0.12}><hr class="rule" /></Reveal>
            <Reveal delay={0.14}>
              <p class="suite-detail__intro">{suite.intro}</p>
            </Reveal>
            <Reveal delay={0.16}>
              <ul class="suite-detail__features">
                {suite.features.map((f) => (
                  <li>{f}</li>
                ))}
              </ul>
            </Reveal>
            <Reveal delay={0.18}>
              <div class="suite-detail__foot">
                <Button href={bookingHref} variant="primary">
                  Reserve This Suite
                </Button>
                <a class="suite-detail__gallery-link" href="/gallery">
                  View more photos
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </Reveal>
          </div>
        </div>
      </section>

      {/* Dynamic CTA band, placed between the 2nd (Roma) and 3rd (Capri) suite. */}
      {i === 1 && (
        <section class="suites-cta" aria-labelledby="suites-cta-title">
          <div class="suites-cta__media" data-parallax-scope>
            <Image
              class="suites-cta__img"
              src={ctaImage}
              alt="Villa Dolce Vita lit warm at dusk, seen from above"
              widths={[768, 1280, 1920, 2560]}
              sizes="100vw"
              loading="lazy"
              data-parallax="0.12"
            />
            <div class="suites-cta__scrim" aria-hidden="true" />
          </div>
          <div class="wrap suites-cta__inner">
            <Reveal as="p" class="eyebrow eyebrow--gold">
              Ready When You Are
            </Reveal>
            <Reveal as="h2" id="suites-cta-title" delay={0.05}>
              Find the Suite That's Yours
            </Reveal>
            <Reveal delay={0.1}>
              <p class="suites-cta__lead">
                Five suites, one unforgettable view — from €{lowestRate} a
                night. Tell us your dates and we'll match you with the room
                that fits your stay, then handle every detail before you
                arrive.
              </p>
            </Reveal>
            <Reveal as="div" class="suites-cta__actions" delay={0.15}>
              <Button href={bookingHref} variant="primary" onDark>
                Check Availability
              </Button>
              <a class="suites-cta__wa" href={contact.whatsappHref}>
                Or message us on WhatsApp
                <span aria-hidden="true">→</span>
              </a>
            </Reveal>
          </div>
        </section>
      )}
      </>
    ))
  }

  <!-- IN EVERY SUITE (branding detail) -->
  <section class="in-suite">
    <div class="in-suite__media" data-parallax-scope>
      <Image
        class="in-suite__img"
        src={mockups.welcomeLetter}
        alt="Villa Dolce Vita welcome letter and room key laid out in a suite"
        widths={[768, 1280, 1920, 2560]}
        sizes="100vw"
        loading="lazy"
        data-parallax="0.1"
      />
      <div class="in-suite__scrim" aria-hidden="true"></div>
    </div>
    <div class="wrap in-suite__inner">
      <Reveal as="p" class="eyebrow eyebrow--gold">In Every Suite</Reveal>
      <Reveal as="h2" delay={0.05}>The Little Things, Handled</Reveal>
      <Reveal delay={0.1}><hr class="rule" /></Reveal>
      <Reveal delay={0.12}>
        <p class="in-suite__lead">
          A handwritten welcome note and your room key waiting on arrival.
          Honey, olives and citrus from the farm. New bedding and adjustable
          pillows. A WhatsApp concierge on hand throughout your stay — and an
          optional butler service for those who'd like to be looked after
          completely.
        </p>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 0.9rem + 1.2vw, 1.8rem);
    line-height: 1.5;
    color: var(--c-forest);
  }

  /* Constrain the editorial pair to the site's content column so the image
     never sprawls edge-to-edge, and centre it on the page. */
  .suite-detail__inner {
    max-width: var(--content-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .suite-detail__inner.is-reverse .suite-detail__media {
    order: 2;
  }
  .suite-detail__media {
    position: relative;
  }
  .suite-detail__copy {
    position: relative;
  }
  /* Oversized index numeral — quiet editorial marker behind the kicker. */
  .suite-detail__num {
    position: absolute;
    top: -0.55em;
    right: 0;
    font-family: var(--font-display);
    font-size: clamp(4rem, 9vw, 7rem);
    line-height: 1;
    color: var(--accent-deep);
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
  }
  .suite-detail__kicker {
    position: relative;
    z-index: 1;
  }
  .suite-detail__img {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 4 / 3;
    box-shadow: var(--shadow-soft);
  }
  @media (min-width: 901px) {
    .suite-detail__img {
      aspect-ratio: 5 / 6;
    }
  }

  /* ---- Gallery ---- */
  .suite-gallery__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity var(--dur-med, 0.5s) var(--ease-out, ease);
    pointer-events: none;
  }
  .suite-gallery__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  /* First slide stays visible before hydration / with JS off. */
  .suite-detail__img :global(img.suite-gallery__slide:first-of-type) {
    opacity: 1;
  }

  .suite-gallery__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.82);
    color: var(--c-forest, #1e3a2f);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--dur-fast, 0.25s), background var(--dur-fast, 0.25s);
    z-index: 2;
    backdrop-filter: blur(2px);
  }
  .suite-gallery__nav--prev { left: 0.8rem; }
  .suite-gallery__nav--next { right: 0.8rem; }
  .suite-detail__img:hover .suite-gallery__nav,
  .suite-gallery__nav:focus-visible {
    opacity: 1;
  }
  .suite-gallery__nav:hover {
    background: #fff;
  }

  .suite-gallery__count {
    position: absolute;
    bottom: 0.9rem;
    right: 0.9rem;
    z-index: 2;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
    background: rgba(20, 20, 20, 0.55);
    color: #fff;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .suite-gallery__thumbs {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.8rem;
    overflow-x: auto;
    scrollbar-width: thin;
    padding-bottom: 0.2rem;
  }
  .suite-gallery__thumb {
    flex: 0 0 auto;
    width: 4.5rem;
    aspect-ratio: 4 / 3;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    background: none;
    opacity: 0.6;
    transition: opacity var(--dur-fast, 0.25s), border-color var(--dur-fast, 0.25s);
  }
  .suite-gallery__thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .suite-gallery__thumb:hover {
    opacity: 0.85;
  }
  .suite-gallery__thumb.is-active {
    opacity: 1;
    border-color: var(--accent-deep, #c47a5a);
  }

  @media (prefers-reduced-motion: reduce) {
    .suite-gallery__slide {
      transition: none;
    }
  }

  .suite-detail__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--accent);
    color: var(--c-forest);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-sm);
  }
  .suite-detail__tagline {
    color: var(--accent-deep);
    font-size: 1.05rem;
    margin-top: 0.4rem;
  }
  .suite-detail__intro {
    color: var(--text-muted);
  }
  .suite-detail__features {
    list-style: none;
    margin: 1.6rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }
  .suite-detail__features li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--text-muted);
  }
  .suite-detail__features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    border: 1px solid var(--accent-deep);
    transform: rotate(45deg);
  }
  /* Price sits just below the tagline — large and prominent. */
  .suite-detail__from {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .suite-detail__from-label {
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }
  .suite-detail__from strong {
    color: var(--text);
    font-size: clamp(2.2rem, 1.6rem + 2vw, 3.2rem);
    font-family: var(--font-display);
    line-height: 1;
  }
  .suite-detail__from-unit {
    font-size: 0.9rem;
  }
  /* Actions row — left-aligned on every suite (reverse rows too). */
  .suite-detail__foot {
    margin-top: 2.2rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1.2rem 1.6rem;
    flex-wrap: wrap;
  }
  .suite-detail__gallery-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      gap var(--dur-fast) var(--ease-out);
  }
  .suite-detail__gallery-link span {
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .suite-detail__gallery-link:hover {
    border-color: currentColor;
  }
  .suite-detail__gallery-link:hover span {
    transform: translateX(3px);
  }

  /* ---- Closing CTA (full-bleed) ---- */
  .suites-cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: var(--c-ivory);
    padding-block: clamp(5rem, 12vw, 9rem);
    text-align: center;
  }
  .suites-cta__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .suites-cta__img {
    width: 100%;
    height: 120%;
    object-fit: cover;
    will-change: transform;
  }
  .suites-cta__scrim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 50% 50%, rgba(18, 26, 22, 0.45), rgba(18, 26, 22, 0.72)),
      linear-gradient(to bottom, rgba(18, 26, 22, 0.6), rgba(18, 26, 22, 0.55));
  }
  .suites-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 56rem;
    margin-inline: auto;
  }
  .suites-cta__inner .eyebrow {
    justify-content: center;
  }
  .suites-cta__inner :global(.rule) {
    margin-inline: auto;
  }
  .suites-cta__lead {
    margin-top: 1.2rem;
    max-width: 46ch;
    margin-inline: auto;
    color: rgba(243, 238, 230, 0.9);
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.2rem);
    line-height: 1.65;
    text-shadow: 0 1px 20px rgba(0, 0, 0, 0.3);
  }
  .suites-cta__actions {
    margin-top: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem 1.8rem;
    flex-wrap: wrap;
  }
  .suites-cta__wa {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      gap var(--dur-fast) var(--ease-out);
  }
  .suites-cta__wa span {
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .suites-cta__wa:hover {
    border-color: currentColor;
  }
  .suites-cta__wa:hover span {
    transform: translateX(3px);
  }

  /* ---- In Every Suite (full-bleed background) ---- */
  .in-suite {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: var(--c-ivory);
    padding-block: clamp(4rem, 9vw, 6.5rem);
  }
  .in-suite__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .in-suite__img {
    width: 100%;
    height: 118%;
    object-fit: cover;
    will-change: transform;
  }
  /* Darken from the left so the copy stays legible over the imagery. */
  .in-suite__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        105deg,
        rgba(18, 26, 22, 0.92) 0%,
        rgba(18, 26, 22, 0.82) 34%,
        rgba(18, 26, 22, 0.5) 62%,
        rgba(18, 26, 22, 0.32) 100%
      );
  }
  .in-suite__inner {
    max-width: var(--content-max);
    margin-inline: auto;
  }
  .in-suite__inner > :global(*) {
    max-width: 44rem;
  }
  .in-suite__lead {
    color: rgba(243, 238, 230, 0.9);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .suite-detail__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .suite-detail__inner.is-reverse .suite-detail__media {
      order: 0;
    }
    .suite-detail__num {
      font-size: clamp(3rem, 14vw, 4.5rem);
      top: -0.45em;
    }
    .suite-detail__foot {
      justify-content: flex-start;
    }
    /* Stronger, even scrim on narrow screens where copy sits over the art. */
    .in-suite__scrim {
      background: linear-gradient(
        to bottom,
        rgba(18, 26, 22, 0.72),
        rgba(18, 26, 22, 0.88)
      );
    }
  }
</style>

<script>
  // Per-suite photo gallery: thumbnails + prev/next arrows crossfade slides.
  // Runs on load and after Astro view transitions (astro:page-load).
  function initSuiteGalleries() {
    const galleries = document.querySelectorAll<HTMLElement>("[data-suite-gallery]");
    galleries.forEach((gallery) => {
      if (gallery.dataset.galleryReady === "1") return;
      gallery.dataset.galleryReady = "1";

      const slides = Array.from(
        gallery.querySelectorAll<HTMLImageElement>(".suite-gallery__slide"),
      );
      const thumbs = Array.from(
        gallery.querySelectorAll<HTMLButtonElement>("[data-thumb]"),
      );
      const count = gallery.querySelector<HTMLElement>("[data-count]");
      const prev = gallery.querySelector<HTMLButtonElement>("[data-prev]");
      const next = gallery.querySelector<HTMLButtonElement>("[data-next]");
      if (slides.length < 2) return;

      let current = 0;
      const show = (i: number) => {
        current = (i + slides.length) % slides.length;
        slides.forEach((s, si) => s.classList.toggle("is-active", si === current));
        thumbs.forEach((t, ti) => {
          const on = ti === current;
          t.classList.toggle("is-active", on);
          t.setAttribute("aria-selected", on ? "true" : "false");
        });
        if (count) count.textContent = `${current + 1} / ${slides.length}`;
      };

      thumbs.forEach((t, ti) => t.addEventListener("click", () => show(ti)));
      prev?.addEventListener("click", () => show(current - 1));
      next?.addEventListener("click", () => show(current + 1));
    });
  }

  document.addEventListener("astro:page-load", initSuiteGalleries);
  initSuiteGalleries();
</script>
