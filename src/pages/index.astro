---
/**
 * Home — the cinematic, scroll-driven landing page.
 * Sections follow content.md's Home order:
 * Hero → Welcome → 15 min to Massa Marittima → The Experience (pinned) →
 * Suites → Beyond the Villa → Weddings → Testimonials → Journal → Final CTA.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import FeatureBar from "../components/FeatureBar.astro";
import SplitSection from "../components/SplitSection.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SuiteCard from "../components/SuiteCard.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";
import BackgroundVideo from "../components/BackgroundVideo.astro";
import TestimonialCarousel from "../components/TestimonialCarousel.tsx";
import { Image } from "astro:assets";
import { bookingHref } from "../data/site";
import { suites } from "../data/suites";
import { testimonials } from "../data/testimonials";
import { photos } from "../data/media";
import { experienceLinks } from "../data/experiences";
import { journalTeasers } from "../data/journal";

// Metro mosaic order: signature (highest rate) suite first so it takes the
// hero tile, then the rest by descending rate for a balanced layout.
const orderedSuites = [...suites].sort((a, b) => b.fromNight - a.fromNight);
---

<BaseLayout>
  <!-- HERO -->
  <Hero eyebrow="Massa Marittima, Tuscany" video="laDolceVita">
    <Fragment slot="title">Under The<br /><em>Tuscan Sun</em></Fragment>
    <Fragment slot="subtitle">A Tuscan sanctuary of beauty, soul & timeless living.</Fragment>
    <Fragment slot="actions">
      <Button href={bookingHref} variant="primary">Check Availability</Button>
    </Fragment>
  </Hero>

  <!-- FEATURE BAR — six-icon amenities strip, now its own band below the hero -->
  <FeatureBar />

  <!-- WELCOME -->
  <SplitSection
    eyebrow="Welcome to Villa Dolce Vita"
    title="A Timeless Escape in the Heart of Tuscany"
    reverse
  >
    <Image
      slot="media"
      class="welcome-cutout"
      src={photos.welcomeVilla}
      alt="Villa Dolce Vita perched on the Tuscan hillside"
      widths={[560, 900, 1300, 1800]}
      sizes="(max-width: 900px) 92vw, 52vw"
      loading="lazy"
    />
    <p>
      After years in corporate America, Linda and Frank traded the fast-paced life for the
      rolling hills of Tuscany. What they built is a ten-hectare estate of olive groves,
      vineyards, and open pastures, home to a handful of rescued animals and five private
      suites, perched high enough to see the sea.
    </p>
    <p>
      It isn't quite a hotel and it isn't quite a farmhouse. It's somewhere in between, run by
      two people who actually live here, for guests who want the real version of a Tuscan
      escape rather than the postcard.
    </p>
    <div class="actions">
      <Button href="/about-us" variant="ghost">Read our story</Button>
    </div>
  </SplitSection>

  <!-- 15 MIN TO MASSA MARITTIMA — full-bleed image with an overlaid text panel -->
  <section class="townband" data-reveal aria-labelledby="townband-title">
    <Image
      class="townband__bg"
      src={photos.massaMarittima}
      alt="Massa Marittima's medieval cathedral and piazza"
      widths={[768, 1100, 1440, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="townband__scrim" aria-hidden="true"></div>
    <div class="townband__inner wrap">
      <div class="townband__panel">
        <p class="eyebrow eyebrow--gold">15 Minutes To</p>
        <h2 class="townband__title" id="townband-title">Massa Marittima</h2>
        <hr class="rule" />
        <p class="townband__body">
          Cobbled streets, medieval charm, and a thousand-year-old cathedral — a fifteen-minute
          drive from your terrace, with the sea on the horizon. The rare town you can visit on a
          whim, not a whole day out.
        </p>
        <Button href="/experiences#day-trips" variant="secondary" onDark class="townband__cta">
          Discover the Town
        </Button>
      </div>
    </div>
  </section>

  <!-- THE EXPERIENCE — pinned crossfade over a night-sky video -->
  <section class="experience" data-pin-fade>
    <BackgroundVideo video="nightSky" overlay={false} />
    <div class="experience__scrim" aria-hidden="true"></div>
    <div class="experience__layers wrap">
      <div class="experience__layer" data-pin-layer>
        <p class="eyebrow eyebrow--gold">The Experience</p>
        <h2>Nobody Needs You Right Now</h2>
        <p class="experience__body">
          Your phone still works up here. That's the problem, usually. Villa Dolce Vita doesn't
          take it away from you. It just puts you on top of a hill with a view of two countries'
          worth of coastline and lets the silence do what silence does.
        </p>
      </div>
      <div class="experience__layer" data-pin-layer>
        <h2>There's a Pool. There's a Forest That's a Sauna.</h2>
        <p class="experience__body">
          There are two dogs who have never had a bad day in their lives and will not let you
          have one either. Somewhere around hour six, most guests stop checking their email. By
          day two, they've forgotten why they were checking it in the first place.
        </p>
      </div>
      <div class="experience__layer" data-pin-layer>
        <h2>Rest Isn't a Program Here.</h2>
        <p class="experience__body">
          It's just what happens when you stop being anywhere else.
        </p>
        <div class="experience__actions">
          <Button href="/experiences" variant="secondary" onDark>Explore Experiences</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- THE SUITES — asymmetric: the premium suite leads, the rest support it. -->
  <section class="section bg-ivory">
    <div class="wrap">
      <div class="suites-head">
        <SectionHeader eyebrow="The Suites" title="Five Rooms, One View" align="left">
          <p>Sophisticated comfort and genuine charm, curated for real rest.</p>
        </SectionHeader>
        <Button href="/rooms" variant="ghost" class="suites-head__cta">Explore all suites</Button>
      </div>
      <div class="suites-metro">
        {
          orderedSuites.map((s, i) => (
            <div class:list={["suites-metro__cell", `suites-metro__cell--${i}`]}>
              <SuiteCard suite={s} featured={i === 0} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- BEYOND THE VILLA -->
  <section class="section bg-dark beyond">
    <div class="wrap">
      <SectionHeader eyebrow="Beyond the Villa" title="This Is What There Is to Do Here, Beyond Nothing at All" align="center" onDark>
        <p style="color:var(--text-on-dark-muted)">
          Wine tastings ten minutes away. Horses through the olive groves. A cooking class that
          ends with a flaming wheel of parmigiano.
        </p>
      </SectionHeader>
      <ul class="beyond__grid">
        {
          experienceLinks.map((e) => (
            <li class="beyond__item" data-reveal>
              <a href={e.href}>
                <span class="beyond__name">{e.label}</span>
                <span class="beyond__arrow">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- WEDDINGS -->
  <SplitSection
    eyebrow="Weddings"
    title="A Marble Terrace on Top of a Hill"
    image={photos.hillsPinkDawn}
    imageAlt="Hilltop terrace at dawn, sea on the horizon"
    reverse
  >
    <p>
      Fifty to a hundred guests, a marble terrace on top of a hill, and a sunset that sets
      directly behind Elba and Corsica if the timing is right. Villa Dolce Vita was built for
      weddings this size, not scaled down to fit them.
    </p>
    <div class="actions">
      <Button href="/weddings-events" variant="ghost">Plan your wedding</Button>
    </div>
  </SplitSection>

  <!-- TESTIMONIALS -->
  <section class="section bg-charcoal testimonials">
    <div class="wrap">
      <SectionHeader eyebrow="What Guests Say" title="Kind Words" align="center" onDark />
      <TestimonialCarousel client:visible items={testimonials} />
    </div>
  </section>

  <!-- JOURNAL -->
  <section class="section bg-ivory">
    <div class="wrap">
      <div class="suites-head">
        <SectionHeader eyebrow="From the Journal" title="A Running Local Guide" align="left">
          <p>Things to do nearby, restaurant spotlights, and life at the estate.</p>
        </SectionHeader>
        <Button href="/journal" variant="ghost" class="suites-head__cta">Read the Journal</Button>
      </div>
      {/* Featured overlay posts as a carousel — all articles live here. */}
      <div class="jcarousel" data-jcarousel>
        <div class="jcarousel__track">
          {
            journalTeasers.map((a, i) => (
              <a
                class:list={["jfeature", "jcarousel__slide", { "is-active": i === 0 }]}
                href={`/journal/${a.slug}`}
                data-jslide
                aria-hidden={i === 0 ? "false" : "true"}
              >
                <div class="jfeature__media">
                  <Image
                    src={a.image}
                    alt={a.imageAlt}
                    widths={[768, 1200, 1600, 2000]}
                    sizes="(max-width: 900px) 92vw, 88vw"
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                </div>
                <div class="jfeature__scrim" aria-hidden="true" />
                <div class="jfeature__text">
                  <span class="eyebrow eyebrow--gold">{a.category}</span>
                  <h3 class="jfeature__title">{a.title}</h3>
                  <p class="jfeature__excerpt">{a.excerpt}</p>
                  <span class="jfeature__more">Read the story →</span>
                </div>
              </a>
            ))
          }
        </div>

        <div class="jcarousel__controls">
          <div class="jcarousel__dots" role="tablist" aria-label="Journal articles">
            {
              journalTeasers.map((a, i) => (
                <button
                  type="button"
                  class:list={["jcarousel__dot", { "is-active": i === 0 }]}
                  data-jdot
                  role="tab"
                  aria-selected={i === 0 ? "true" : "false"}
                  aria-label={a.title}
                />
              ))
            }
          </div>
          <div class="jcarousel__arrows">
            <button type="button" class="jcarousel__arrow" data-jprev aria-label="Previous article">‹</button>
            <button type="button" class="jcarousel__arrow" data-jnext aria-label="Next article">›</button>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Journal carousel: crossfade slides with dots + arrows + autoplay.
      document.querySelectorAll<HTMLElement>("[data-jcarousel]").forEach((root) => {
        const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-jslide]"));
        const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-jdot]"));
        if (slides.length < 2) return;

        let index = 0;
        let timer: number | undefined;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const show = (next: number) => {
          index = (next + slides.length) % slides.length;
          slides.forEach((s, i) => {
            const active = i === index;
            s.classList.toggle("is-active", active);
            s.setAttribute("aria-hidden", active ? "false" : "true");
          });
          dots.forEach((d, i) => {
            const active = i === index;
            d.classList.toggle("is-active", active);
            d.setAttribute("aria-selected", active ? "true" : "false");
          });
        };

        const stop = () => {
          if (timer) window.clearInterval(timer);
        };
        const start = () => {
          if (reduce) return;
          stop();
          timer = window.setInterval(() => show(index + 1), 6500);
        };

        dots.forEach((d, i) =>
          d.addEventListener("click", (e) => {
            e.preventDefault();
            show(i);
            start();
          }),
        );
        root.querySelector("[data-jnext]")?.addEventListener("click", (e) => {
          e.preventDefault();
          show(index + 1);
          start();
        });
        root.querySelector("[data-jprev]")?.addEventListener("click", (e) => {
          e.preventDefault();
          show(index - 1);
          start();
        });

        root.addEventListener("mouseenter", stop);
        root.addEventListener("mouseleave", start);
        start();
      });
    </script>
  </section>

  <!-- FINAL CTA -->
  <section class="finalcta">
    <BackgroundVideo video="aerialTownGolden" />
    <div class="finalcta__content wrap">
      <Reveal as="p" class="eyebrow eyebrow--gold">Book direct for the best rate</Reveal>
      <Reveal as="h2" delay={0.05}>Come Sit on the Hill for a While</Reveal>
      <Reveal delay={0.1}><p class="finalcta__sub">Five suites. One view.</p></Reveal>
      <Reveal delay={0.15}>
        <Button href={bookingHref} variant="primary">Check Availability</Button>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  /* Tighten the first two sections under the hero.
     NOTE: .features is rendered by the FeatureBar component, so it doesn't
     carry this page's scope hash — the whole selector must be :global(). */
  :global(.features + .section) {
    padding-top: clamp(2rem, 4vw, 3.5rem);
  }
  /* Welcome split leads straight into the Massa Marittima band — no bottom gap. */
  :global(.features + .section.split) {
    padding-bottom: 0;
  }

  /* "15 minutes to" banner: full-bleed image (native 1280×520 ≈ 32/13)
     with a forest scrim on the left and the text panel overlaid. */
  .townband {
    position: relative;
    width: 100%;
    aspect-ratio: 1280 / 520;
    overflow: hidden;
    display: flex;
    align-items: center;
    /* Sits flush against the Welcome split above and the Experience below. */
    margin-block: 0;
  }
  .townband__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  /* Dark gradient anchored left so the text stays legible over the sky. */
  .townband__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse 60% 75% at 50% 50%,
      rgba(15, 42, 36, 0.6) 0%,
      rgba(15, 42, 36, 0.4) 45%,
      rgba(15, 42, 36, 0.12) 75%,
      rgba(15, 42, 36, 0) 100%
    );
  }
  .townband__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .townband__panel {
    color: var(--c-ivory);
    max-width: 52ch;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .townband__title {
    font-size: var(--fs-h2);
    margin-top: 0.6rem;
  }
  .townband__body {
    color: var(--text-on-dark-muted);
    font-size: 1rem;
    line-height: 1.65;
    max-width: 46ch;
  }
  .townband__cta {
    margin-top: 1.8rem;
    align-self: center;
  }
  /* On narrow screens the image is too short to fit the copy; let it grow
     taller and cover the full width behind a stronger scrim. */
  @media (max-width: 820px) {
    .townband {
      aspect-ratio: auto;
      min-height: 30rem;
    }
    .townband__scrim {
      background: linear-gradient(
        180deg,
        rgba(15, 42, 36, 0.55) 0%,
        rgba(15, 42, 36, 0.82) 55%,
        rgba(15, 42, 36, 0.9) 100%
      );
    }
    .townband__panel {
      max-width: none;
    }
  }

  /* Welcome section: transparent PNG shown free — no arch mask, no frame. */
  .welcome-cutout {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 30px 50px rgba(15, 42, 36, 0.18));
  }

  /* Section header with a link that sits on the title's baseline, then the grid. */
  .suites-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem 3rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-group);
  }
  .suites-head :global(.sechead) {
    /* header owns the bottom margin now */
    margin-bottom: 0;
    flex: 1 1 30ch;
  }
  .suites-head__cta {
    flex: 0 0 auto;
    /* nudge down to line up with the first line of the title */
    transform: translateY(0.6rem);
    white-space: nowrap;
  }
  @media (max-width: 720px) {
    .suites-head__cta {
      transform: none;
    }
  }
  /* ---- Suites: metro mosaic ----
     4 equal columns, 2 equal rows. The signature suite (cell 0) claims a 2×2
     hero tile on the left; the four supporting suites fill a clean 2×2 grid
     on the right — no gaps.

       [ 0 0 1 2 ]
       [ 0 0 3 4 ]                                                        */
  .suites-metro {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, minmax(15rem, 1fr));
    gap: clamp(1rem, 1.8vw, 1.6rem);
  }
  .suites-metro__cell {
    display: flex;
    min-width: 0;
  }
  .suites-metro__cell > :global(.suite) {
    width: 100%;
  }
  /* Signature suite: big hero tile spanning the left half. */
  .suites-metro__cell--0 {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }
  .suites-metro__cell--1 { grid-column: 3; grid-row: 1; }
  .suites-metro__cell--2 { grid-column: 4; grid-row: 1; }
  .suites-metro__cell--3 { grid-column: 3; grid-row: 2; }
  .suites-metro__cell--4 { grid-column: 4; grid-row: 2; }

  /* Every card fills its tile; images grow to consume the tile height. */
  .suites-metro__cell :global(.suite__media) {
    aspect-ratio: auto;
    flex: 1 1 auto;
    min-height: 0;
  }

  .center-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-group);
  }

  /* Tablet: 2 columns; hero spans the full width on top, then a 2×2 grid. */
  @media (max-width: 1000px) {
    .suites-metro {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      grid-auto-rows: 1fr;
    }
    .suites-metro__cell--0 {
      grid-column: 1 / 3;
      grid-row: auto;
    }
    .suites-metro__cell--1,
    .suites-metro__cell--2,
    .suites-metro__cell--3,
    .suites-metro__cell--4 {
      grid-column: auto;
      grid-row: auto;
    }
    .suites-metro__cell :global(.suite__media) {
      aspect-ratio: 4 / 5;
      flex: 0 0 auto;
    }
    .suites-metro__cell--0 :global(.suite__media) {
      aspect-ratio: 16 / 10;
    }
  }
  /* Phone: single column stack. */
  @media (max-width: 560px) {
    .suites-metro {
      grid-template-columns: 1fr;
    }
    .suites-metro__cell--0 {
      grid-column: 1;
    }
    .suites-metro__cell :global(.suite__media),
    .suites-metro__cell--0 :global(.suite__media) {
      aspect-ratio: 4 / 3;
    }
  }
  @media (max-width: 900px) {
    .suites-head__cta {
      margin-bottom: 1.5rem;
    }
  }

  /* The Experience — pinned */
  .experience {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    color: var(--c-ivory);
    overflow: hidden;
  }
  .experience__scrim {
    position: absolute;
    inset: 0;
    background: rgba(15, 42, 36, 0.62);
  }
  .experience__layers {
    position: relative;
    z-index: 2;
    display: grid;
  }
  .experience__layer {
    grid-area: 1 / 1;
    max-width: 46ch;
  }

  /* Reduced motion / no-JS: the pin crossfade can't run, so stack the layers
     vertically and let them all read normally instead of overlapping. */
  @media (prefers-reduced-motion: reduce) {
    .experience {
      min-height: 0;
      padding-block: var(--section-y);
    }
    .experience__layers {
      display: block;
    }
    .experience__layer {
      max-width: 60ch;
    }
    .experience__layer + .experience__layer {
      margin-top: 3rem;
    }
  }
  .experience__layer h2 {
    margin: 1rem 0 1.5rem;
  }
  .experience__body {
    color: var(--text-on-dark-muted);
    font-size: 1.05rem;
  }
  .experience__actions {
    margin-top: 2rem;
  }

  /* Beyond the Villa list */
  .beyond__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--line-on-dark);
    border: 1px solid var(--line-on-dark);
  }
  .beyond__item a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 1.8rem;
    background: var(--c-forest);
    transition: background var(--dur) var(--ease-out);
  }
  .beyond__item a:hover {
    background: rgba(210, 180, 140, 0.1);
  }
  .beyond__name {
    font-family: var(--font-display);
    font-size: 1.3rem;
  }
  .beyond__arrow {
    color: var(--accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .beyond__item a:hover .beyond__arrow {
    transform: translateX(6px);
  }

  /* Journal — carousel of featured overlay posts. */
  .jcarousel {
    position: relative;
  }
  .jcarousel__track {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    aspect-ratio: 16 / 9;
  }

  /* Featured: full-bleed image with copy overlaid on a gradient. */
  .jfeature {
    position: relative;
    display: block;
    overflow: hidden;
    color: var(--c-ivory);
  }
  /* Slides fill the track and crossfade (track holds the aspect-ratio). */
  .jcarousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    z-index: 0;
    transition: opacity 0.8s var(--ease-out), visibility 0s linear 0.8s;
  }
  .jcarousel__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
    transition: opacity 0.8s var(--ease-out), visibility 0s;
  }
  .jfeature__media {
    position: absolute;
    inset: 0;
  }
  .jfeature__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .jfeature__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(15, 42, 36, 0.88) 0%,
      rgba(15, 42, 36, 0.45) 42%,
      rgba(15, 42, 36, 0) 68%
    );
  }
  .jfeature__text {
    position: absolute;
    left: 0;
    bottom: 0;
    padding: clamp(1.8rem, 4vw, 3.5rem);
    max-width: 60ch;
  }
  .jfeature__title {
    margin-top: 0.7rem;
    font-size: clamp(1.7rem, 1.2rem + 1.8vw, 2.8rem);
    line-height: 1.12;
    color: var(--c-ivory);
  }
  .jfeature__excerpt {
    margin-top: 0.9rem;
    color: var(--text-on-dark-muted);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 56ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .jfeature__more {
    display: inline-block;
    margin-top: 1.3rem;
    font-size: 0.74rem;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .jfeature:hover .jfeature__more {
    transform: translateX(4px);
  }

  /* Slow Ken-Burns zoom while a slide is the active one. */
  .jcarousel__slide .jfeature__media :global(img) {
    transform: scale(1);
  }
  .jcarousel__slide.is-active .jfeature__media :global(img) {
