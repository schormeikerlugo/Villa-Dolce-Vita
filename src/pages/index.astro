---
/**
 * Home — the cinematic, scroll-driven landing page.
 * Sections follow content.md's Home order:
 * Hero → Welcome → 15 min to Massa Marittima → The Experience (pinned) →
 * Suites → Beyond the Villa → Weddings → Testimonials → Journal → Final CTA.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SplitSection from "../components/SplitSection.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SuiteCard from "../components/SuiteCard.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";
import BackgroundVideo from "../components/BackgroundVideo.astro";
import TestimonialCarousel from "../components/TestimonialCarousel.tsx";
import { Image } from "astro:assets";
import { bookingHref } from "../data/site";
import { suites } from "../data/suites";
import { testimonials } from "../data/testimonials";
import { photos } from "../data/media";
import { experienceLinks } from "../data/experiences";
import { journalTeasers } from "../data/journal";

// Metro mosaic order: signature (highest rate) suite first so it takes the
// hero tile, then the rest by descending rate for a balanced layout.
const orderedSuites = [...suites].sort((a, b) => b.fromNight - a.fromNight);
---

<BaseLayout>
  <!-- HERO -->
  <Hero eyebrow="Massa Marittima, Tuscany" video="laDolceVita" booking>
    <Fragment slot="title">Under The<br /><em>Tuscan Sun</em></Fragment>
  </Hero>

  <!-- WELCOME -->
  <SplitSection
    eyebrow="Welcome to Villa Dolce Vita"
    title="A Timeless Escape in the Heart of Tuscany"
    reverse
  >
    <Image
      slot="media"
      class="welcome-cutout"
      src={photos.welcomeVilla}
      alt="Villa Dolce Vita perched on the Tuscan hillside"
      widths={[560, 900, 1300, 1800]}
      sizes="(max-width: 900px) 92vw, 52vw"
      loading="lazy"
      data-mouse-parallax="14"
    />
    <p>
      After years in corporate America, Linda and Frank traded the fast-paced life for the
      rolling hills of Tuscany. What they built is a ten-hectare estate of olive groves,
      vineyards, and open pastures, home to a handful of rescued animals and five private
      suites, perched high enough to see the sea.
    </p>
    <p>
      It isn't quite a hotel and it isn't quite a farmhouse. It's somewhere in between, run by
      two people who actually live here, for guests who want the real version of a Tuscan
      escape rather than the postcard.
    </p>
    <div class="actions">
      <Button href="/our-story" variant="ghost">Read our story</Button>
    </div>
  </SplitSection>

  <!-- 15 MIN TO MASSA MARITTIMA — full-bleed image with an overlaid text panel -->
  <section class="townband" data-reveal aria-labelledby="townband-title">
    <Image
      class="townband__bg"
      src={photos.massaMarittima}
      alt="Massa Marittima's medieval cathedral and piazza"
      widths={[768, 1100, 1440, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="townband__scrim" aria-hidden="true"></div>
    <div class="townband__inner wrap">
      <div class="townband__panel">
        <p class="eyebrow eyebrow--gold">15 Minutes To</p>
        <h2 class="townband__title" id="townband-title">Massa Marittima</h2>
        <hr class="rule" />
        <p class="townband__body">
          Cobbled streets, medieval charm, and a thousand-year-old cathedral — a fifteen-minute
          drive from your terrace, with the sea on the horizon. The rare town you can visit on a
          whim, not a whole day out.
        </p>
        <Button href="/experiences#day-trips" variant="secondary" onDark class="townband__cta">
          Discover the Town
        </Button>
      </div>
    </div>
  </section>

  <!-- THE SUITES — metro mosaic: a signature hero tile + a 2×2 grid. -->
  <section class="section bg-ivory">
    <div class="wrap">
      <div class="suites-head">
        <SectionHeader eyebrow="The Suites" title="Five Suites, One View" align="center">
          <p>Sophisticated comfort and genuine charm, curated for real rest.</p>
        </SectionHeader>
        <Button href="/suites" variant="ghost" class="suites-head__cta">Explore all suites</Button>
      </div>
      <div class="suites-metro">
        {
          orderedSuites.map((s, i) => (
            <div class:list={["suites-metro__cell", `suites-metro__cell--${i}`]}>
              <SuiteCard suite={s} featured={i === 0} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- BEYOND THE VILLA -->
  <section class="section bg-dark beyond">
    <div class="wrap">
      <SectionHeader eyebrow="Beyond the Villa" title="This Is What There Is to Do Here, Beyond Nothing at All" align="center" onDark class="beyond-head">
        <p style="color:var(--text-on-dark-muted)">
          Wine tastings ten minutes away. Horses through the olive groves. A cooking class that
          ends with a flaming wheel of parmigiano.
        </p>
      </SectionHeader>
      <ul class="beyond__grid">
        {
          experienceLinks.map((e) => (
            <li class="beyond__item" data-reveal>
              <a href={e.href}>
                <span class="beyond__name">{e.label}</span>
                <span class="beyond__arrow">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- JOURNAL -->
  <section class="section bg-ivory">
    <div class="wrap">
      <div class="journal-head">
        <SectionHeader eyebrow="From the Journal" title="A Running Local Guide" align="center">
          <p>Things to do nearby, restaurant spotlights, and life at the estate.</p>
        </SectionHeader>
        <Button href="/journal" variant="ghost" class="journal-head__cta">Read the Journal</Button>
      </div>
      {/* Journal posts as an alternating editorial zigzag: text one side,
          image the other, flipping on every row. */}
      <div class="jzig">
        {
          journalTeasers.map((a, i) => (
            <a
              class:list={["jrow", { "jrow--reverse": i % 2 === 0 }]}
              href={`/journal/${a.slug}`}
              data-reveal
              data-reveal-delay={i * 0.05}
            >
              <div class="jrow__media">
                <Image
                  src={a.image}
                  alt={a.imageAlt}
                  widths={[600, 900, 1300]}
                  sizes="(max-width: 860px) 92vw, 48vw"
                  loading="lazy"
                />
              </div>
              <div class="jrow__body">
                <span class="eyebrow eyebrow--gold">{a.category}</span>
                <h2 class="jrow__title">{a.title}</h2>
                <p class="jrow__excerpt">{a.excerpt}</p>
                <span class="jrow__more">Read the story →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section bg-charcoal testimonials">
    <div class="wrap">
      <SectionHeader eyebrow="What Guests Say" title="Kind Words" align="center" onDark />
      <TestimonialCarousel client:load items={testimonials} />
    </div>
  </section>

  <!-- WEDDINGS & EVENTS — editorial teaser: oversized headline, meta + copy +
       actions, and a staggered three-photo strip linking to /weddings-events. -->
  <section class="section bg-ivory weddings" aria-labelledby="weddings-title">
    <div class="wrap weddings__split">
      <div class="weddings__intro">
        <Reveal as="p" class="eyebrow eyebrow--diamond weddings__eyebrow">Weddings &amp; Events</Reveal>
        <Reveal as="h2" delay={0.05} class="weddings__title" id="weddings-title">
          Weddings Under<br /><em>the Tuscan Sun</em>
        </Reveal>

        <div class="weddings__lead">
          <Reveal as="p" class="weddings__copy" delay={0.1}>
            Ceremonies on the hilltop terrace, cocktail hour rolling straight into sunset, and a
            reception that spills from the marble into the vineyard rows — with the sea and the
            islands on the horizon.
          </Reveal>
          <Reveal class="weddings__actions" delay={0.14}>
            <Button href="/weddings-events" variant="primary">Explore Weddings</Button>
          </Reveal>
        </div>
      </div>

      <div class="weddings__gallery">
        <figure class="wtile wtile--1" data-reveal data-reveal-delay={0.05}>
          <Image
            src={photos.weddingVeil}
            alt="Bride and groom beneath a veil in the golden Tuscan light"
            widths={[420, 640, 900]}
            sizes="(max-width: 860px) 92vw, 30vw"
            loading="lazy"
          />
        </figure>
        <figure class="wtile wtile--2" data-reveal data-reveal-delay={0.12}>
          <Image
            src={photos.weddingDance}
            alt="A couple's first dance, gown lit against the dark"
            widths={[420, 640, 900]}
            sizes="(max-width: 860px) 92vw, 30vw"
            loading="lazy"
          />
        </figure>
        <figure class="wtile wtile--3" data-reveal data-reveal-delay={0.19}>
          <Image
            src={photos.weddingBouquet}
            alt="Bride holding an illuminated bouquet beside the groom"
            widths={[420, 640, 900]}
            sizes="(max-width: 860px) 92vw, 30vw"
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="finalcta">
    <BackgroundVideo video="aerialTownGolden" />
    <div class="finalcta__content wrap">
      <Reveal as="p" class="eyebrow eyebrow--gold">Book direct for the best rate</Reveal>
      <Reveal as="h2" delay={0.05}>Come Sit on the Hill for a While</Reveal>
      <Reveal delay={0.1}><p class="finalcta__sub">Five suites. One view.</p></Reveal>
      <Reveal delay={0.15}>
        <Button href={bookingHref} variant="primary">Check Availability</Button>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  /* Section header with a link that sits on the title's baseline, then the grid. */
  .suites-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: var(--space-group);
  }
  .suites-head :global(.sechead) {
    /* header owns the bottom margin now */
    margin-bottom: 0;
  }
  .suites-head__cta {
    flex: 0 0 auto;
    white-space: nowrap;
  }
  /* ---- Suites: metro mosaic ----
     4 equal columns, 2 equal rows. The signature suite (cell 0) claims a 2×2
     hero tile on the left; the four supporting suites fill a clean 2×2 grid
     on the right — no gaps.

       [ 0 0 1 2 ]
       [ 0 0 3 4 ]                                                        */
  .suites-metro {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, minmax(8.8rem, 1fr));
    gap: clamp(1rem, 1.8vw, 1.6rem);
  }
  .suites-metro__cell {
    display: flex;
    min-width: 0;
  }
  .suites-metro__cell > :global(.suite) {
    width: 100%;
  }
  /* Signature suite: big hero tile spanning the left half. */
  .suites-metro__cell--0 {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }
  .suites-metro__cell--1 { grid-column: 3; grid-row: 1; }
  .suites-metro__cell--2 { grid-column: 4; grid-row: 1; }
  .suites-metro__cell--3 { grid-column: 3; grid-row: 2; }
  .suites-metro__cell--4 { grid-column: 4; grid-row: 2; }

  /* Every card fills its tile; images grow to consume the tile height. */
  .suites-metro__cell :global(.suite__media) {
    aspect-ratio: auto;
    flex: 1 1 auto;
    min-height: 0;
  }

  /* Tablet: 2 columns; hero spans the full width on top, then a 2×2 grid. */
  @media (max-width: 1000px) {
    .suites-metro {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      grid-auto-rows: 1fr;
    }
    .suites-metro__cell--0 {
      grid-column: 1 / 3;
      grid-row: auto;
    }
    .suites-metro__cell--1,
    .suites-metro__cell--2,
    .suites-metro__cell--3,
    .suites-metro__cell--4 {
      grid-column: auto;
      grid-row: auto;
    }
    .suites-metro__cell :global(.suite__media) {
      aspect-ratio: 4 / 5;
      flex: 0 0 auto;
    }
    .suites-metro__cell--0 :global(.suite__media) {
      aspect-ratio: 16 / 10;
    }
  }
  /* Phone: single column stack. */
  @media (max-width: 560px) {
    .suites-metro {
      grid-template-columns: 1fr;
    }
    .suites-metro__cell--0 {
      grid-column: 1;
    }
    .suites-metro__cell :global(.suite__media),
    .suites-metro__cell--0 :global(.suite__media) {
      aspect-ratio: 4 / 3;
    }
  }
  @media (max-width: 900px) {
    .suites-head__cta {
      margin-bottom: 1.5rem;
    }
  }

  /* Tighten the first two sections under the hero.
     NOTE: .features is rendered by the FeatureBar component, so it doesn't
     carry this page's scope hash — the whole selector must be :global(). */
  :global(.features + .section) {
    padding-top: clamp(2rem, 4vw, 3.5rem);
  }

  /* "Beyond the Villa" heading: dial back to a real h2 size (site-wide h2s
     were bumped up to h1 scale). This one title only. */
  :global(.beyond-head h2) {
    font-size: var(--fs-h2);
  }
  /* Welcome split leads straight into the Massa Marittima band — no bottom gap. */
  :global(.features + .section.split) {
    padding-bottom: 0;
  }

  /* "15 minutes to" banner: full-bleed image (native 1280×520 ≈ 32/13)
     with a forest scrim on the left and the text panel overlaid. */
  .townband {
    position: relative;
    width: 100%;
    aspect-ratio: 1280 / 520;
    overflow: hidden;
    display: flex;
    align-items: center;
    /* Sits flush against the Welcome split above and the Experience below. */
    margin-block: 0;
  }
  .townband__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  /* Dark gradient anchored left so the text stays legible over the sky. */
  .townband__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse 60% 75% at 50% 50%,
      rgba(47, 63, 53, 0.62) 0%,
      rgba(47, 63, 53, 0.42) 45%,
      rgba(47, 63, 53, 0.12) 75%,
      rgba(47, 63, 53, 0) 100%
    );
  }
  .townband__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .townband__panel {
    color: var(--c-ivory);
    max-width: 52ch;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .townband__title {
    font-size: var(--fs-h2);
    margin-top: 0.6rem;
  }
  .townband__body {
    color: var(--text-on-dark-muted);
    font-size: 1rem;
    line-height: 1.65;
    max-width: 46ch;
  }
  .townband__cta {
    margin-top: 1.8rem;
    align-self: center;
  }
  /* On narrow screens the image is too short to fit the copy; let it grow
     taller and cover the full width behind a stronger scrim. */
  @media (max-width: 820px) {
    .townband {
      aspect-ratio: auto;
      min-height: 30rem;
    }
    .townband__scrim {
      background: linear-gradient(
        180deg,
        rgba(47, 63, 53, 0.55) 0%,
        rgba(47, 63, 53, 0.82) 55%,
        rgba(47, 63, 53, 0.9) 100%
      );
    }
    .townband__panel {
      max-width: none;
    }
  }

  /* Welcome section: transparent PNG shown free — no arch mask, no frame. */
  .welcome-cutout {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 30px 50px rgba(47, 63, 53, 0.18));
  }

  /* Beyond the Villa list */
  .beyond__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--line-on-dark);
    border: 1px solid var(--line-on-dark);
  }
  .beyond__item a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 1.8rem;
    background: var(--c-forest);
    transition: background var(--dur) var(--ease-out);
  }
  .beyond__item a:hover {
    background: rgba(196, 122, 90, 0.14); /* terracotta wash on hover */
  }
  .beyond__name {
    font-family: var(--font-display);
    font-size: 1.3rem;
  }
  .beyond__arrow {
    color: var(--accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .beyond__item a:hover .beyond__arrow {
    transform: translateX(6px);
  }

  /* Journal section header — centered, with the CTA sitting below the intro. */
  .journal-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-group);
  }
  .journal-head :global(.sechead) {
    margin-bottom: 1.5rem;
  }
  .journal-head__cta {
    align-self: center;
  }

  /* Journal — alternating editorial rows (text / image, flipping each row). */
  .jzig {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 6rem);
  }
  .jrow {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    color: var(--text);
  }
  /* Flip odd rows: image on the left, text on the right. */
  .jrow--reverse .jrow__media {
    order: 2;
  }
  .jrow__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }
  .jrow__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur) var(--ease-out);
  }
  .jrow:hover .jrow__media :global(img) {
    transform: scale(1.05);
  }
  .jrow__body {
    max-width: 46ch;
  }
  .jrow__title {
    margin-top: 0.7rem;
    font-size: var(--fs-h2);
    line-height: 1.14;
  }
  .jrow__excerpt {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }
  .jrow__more {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.74rem;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent-deep);
    position: relative;
  }
  .jrow__more::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(1);
    transform-origin: left;
    transition: transform var(--dur) var(--ease-out);
  }
  .jrow:hover .jrow__more::after {
    transform: scaleX(0);
    transform-origin: right;
  }

  @media (max-width: 860px) {
    .jrow {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    /* On mobile keep image first for every row for a consistent rhythm. */
    .jrow--reverse .jrow__media {
      order: 0;
    }
    .jrow__body {
      max-width: none;
    }
  }

  /* ── WEDDINGS & EVENTS — editorial teaser ────────────────────────────── */
  /* Two columns: text intro left, photo gallery right (fills the empty space). */
  .weddings__split {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .weddings__intro {
    align-self: center;
  }
  .weddings__eyebrow {
    margin-bottom: 0.4rem;
  }
  /* Oversized display headline, hero-scale. Sits left, two lines. */
  .weddings__title {
    font-size: var(--fs-h1);
    line-height: var(--lh-tight);
    letter-spacing: -0.01em;
    margin-bottom: clamp(1.5rem, 3vw, 2.4rem);
  }
  .weddings__title em {
    font-style: italic;
    color: var(--accent-deep);
  }
  /* Copy + action, left-aligned to match the other section intros. */
  .weddings__lead {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(1.5rem, 3vw, 2.2rem);
  }
  .weddings__copy {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 52ch;
  }
  .weddings__actions {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
  }

  /* Staggered three-photo strip. */
  .weddings__gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2.5vw, 2rem);
    align-items: start;
  }
  .wtile {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    /* Entrance animation: fade + rise, staggered per tile. */
    opacity: 0;
    transform: translateY(40px);
    animation: wtile-in 0.9s var(--ease-out) forwards;
  }
  .wtile :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur) var(--ease-out);
  }
  .wtile:hover :global(img) {
    transform: scale(1.04);
  }
  /* Different heights + vertical offsets for editorial rhythm.
     Heights reduced ~15% (wider aspect ratios). */
  .wtile--1 {
    aspect-ratio: 3 / 3.4;
    margin-top: clamp(1rem, 2.5vw, 2.4rem);
    animation-delay: 0.05s;
  }
  .wtile--2 {
    aspect-ratio: 4 / 4.25;
    animation-delay: 0.15s;
  }
  .wtile--2 :global(img) {
    object-position: center 30%;
  }
  .wtile--3 {
    aspect-ratio: 3 / 3.4;
    margin-top: clamp(0.8rem, 2vw, 1.6rem);
    animation-delay: 0.25s;
  }

  @keyframes wtile-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wtile {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
  /* Third tile reads black-and-white. */
  .wtile--3 :global(img) {
    filter: grayscale(1) contrast(1.04);
  }

  @media (max-width: 900px) {
    .weddings__split {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 6vw, 3.5rem);
    }
  }
  @media (max-width: 860px) {
    .weddings__gallery {
      grid-template-columns: 1fr 1fr;
    }
    .wtile--1,
    .wtile--2,
    .wtile--3 {
      margin-top: 0;
    }
    .wtile--3 {
      grid-column: 1 / -1;
      aspect-ratio: 16 / 10;
    }
  }
  @media (max-width: 520px) {
    .weddings__gallery {
      grid-template-columns: 1fr;
    }
  }

  /* Final CTA */
  .finalcta {
    position: relative;
    min-height: 78svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--c-ivory);
    overflow: hidden;
  }
