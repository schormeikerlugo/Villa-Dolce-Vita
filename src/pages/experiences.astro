---
/**
 * Experiences — one page, five anchored sections:
 * #day-trips · #wine-dining · #wellness-area · #animal-sanctuary · #workshops
 * (content.md consolidated five former pages into this one.)
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Button from "../components/Button.astro";
import Reveal from "../components/Reveal.astro";
import { Image } from "astro:assets";
import { photos } from "../data/media";
import {
  dayTrips,
  selfGuided,
  transfers,
  privateTours,
  wellness,
  sanctuaryNotes,
  workshops,
} from "../data/experiences";

const anchors = [
  { id: "day-trips", label: "Day Trips & Tours" },
  { id: "wine-dining", label: "Wine & Dining" },
  { id: "wellness-area", label: "Wellness Area" },
  { id: "animal-sanctuary", label: "Animal Sanctuary" },
  { id: "workshops", label: "Private Workshops" },
];
---

<BaseLayout
  title="Experiences"
  description="Vineyards you can walk to, horses that know the trails, a coastline to charter into, wellness on the hilltop, and a sanctuary of rescued animals — everything within reach of the villa."
>
  <PageHero
    eyebrow="Experiences"
    title="Everything Here Is Optional"
    subtitle="Everything below is optional. Nobody at Villa Dolce Vita is going to hand you an itinerary. But if you want more than a pool and a view, here's what's within reach: vineyards you can walk to, horses that know the trails better than any guide, a coastline you can charter a boat into, and a sanctuary full of animals who were not always this lucky."
    image={photos.butteriRider}
    imageAlt="A butteri rider through the olive groves of Maremma"
  />

  <!-- ANCHOR NAV -->
  <section class="section bg-ivory exp-intro">
    <nav class="anchor-nav wrap" aria-label="Jump to section">
      {anchors.map((a) => <a href={`#${a.id}`}>{a.label}</a>)}
    </nav>
  </section>

  <!-- DAY TRIPS -->
  <section id="day-trips" class="section bg-ivory">
    <div class="wrap">
      <SectionHeader eyebrow="Day Trips & Tours" title="Reachable, Most of It, in Under an Hour">
        <p>
          Whether you prefer structured excursions or the freedom to explore at your own pace,
          everything here is reachable from the villa.
        </p>
      </SectionHeader>

      <div class="daytrip-grid">
        {
          dayTrips.map((d) => (
            <article class="daytrip" data-reveal>
              {d.image && (
                <div class="daytrip__media hoist">
                  <Image
                    src={d.image}
                    alt={d.title}
                    widths={[400, 640, 900]}
                    sizes="(max-width: 900px) 92vw, 30vw"
                    loading="lazy"
                  />
                </div>
              )}
              <h3 class="daytrip__title">{d.title}</h3>
              <p class="daytrip__copy">{d.copy}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SELF-GUIDED CITY GUIDES -->
  <section class="section split--stone">
    <div class="wrap">
      <SectionHeader eyebrow="Self-Guided Adventures" title="If You Have a Car, Point It Here" align="left" />
      <div class="cities">
        {
          selfGuided.map((c) => (
            <article class="city card" data-reveal>
              <h3 class="city__name">{c.city}</h3>
              <div class="city__cols">
                <div>
                  <p class="city__label">What to visit</p>
                  <ul>{c.visit.map((v) => <li>{v}</li>)}</ul>
                </div>
                <div>
                  <p class="city__label">Architecture</p>
                  <ul>{c.architecture.map((v) => <li>{v}</li>)}</ul>
                </div>
                <div>
                  <p class="city__label">Eat & drink</p>
                  <ul>{c.eat.map((v) => <li>{v}</li>)}</ul>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- TRANSFERS + PRIVATE TOURS -->
  <section class="section bg-ivory">
    <div class="wrap tours">
      <div class="transfers" data-reveal>
        <SectionHeader eyebrow="Chauffeured Transfers" title="Move Easily, with Comfort" align="left" />
        <table class="rate-table">
          <thead>
            <tr><th>Route</th><th>Price</th></tr>
          </thead>
          <tbody>
            {transfers.map((t) => (
              <tr><td>{t.route}</td><td>{t.price}</td></tr>
            ))}
          </tbody>
        </table>
        <p class="fineprint">
          A Maserati upgrade is available on the same routes (2 passengers plus driver).
        </p>
      </div>

      <div class="private-tours">
        <SectionHeader eyebrow="Private Luxury Tours" title="Curated, Chauffeured, for Two" align="left" />
        <div class="tour-list">
          {
            privateTours.map((t) => (
              <article class="tour card" data-reveal>
                <header class="tour__head">
                  <h3>{t.title}</h3>
                  <span class="tour__price">{t.price}</span>
                </header>
                <p class="tour__dur">{t.duration}</p>
                <ul>{t.items.map((it) => <li>{it}</li>)}</ul>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- WINE & DINING (teaser to Dining) -->
  <section id="wine-dining" class="section bg-dark winedining">
    <div class="wrap wrap--narrow" style="text-align:center">
      <SectionHeader
        eyebrow="Wine & Dining"
        title="From Tuscan Pizza to a Cellar Spanning Three Countries"
        align="center"
        onDark
      >
        <p style="color:var(--text-on-dark-muted)">
          Private dinners are always available, and the wine list is long enough to take
          seriously. The full menu, dinner pricing, gift baskets, and wine list live on the
          Dining page.
        </p>
      </SectionHeader>
      <Reveal delay={0.15}>
        <Button href="/dining" variant="secondary" onDark>See the full menu & wine list</Button>
      </Reveal>
    </div>
  </section>

  <!-- WELLNESS -->
  <section id="wellness-area" class="section bg-ivory">
    <div class="wrap">
      <SectionHeader eyebrow="Wellness Area" title="Relax. Recharge. Rejuvenate.">
        <p>
          Perched on a mountainside overlooking the valley and the sea, looking out toward Elba,
          Montecristo, and, on the clearest days, Corsica.
        </p>
      </SectionHeader>
      <div class="wellness-grid">
        {
          wellness.map((w) => (
            <article class="wellness" data-reveal>
              <h3 class="wellness__title">
                {w.title}
                {w.soon && <span class="wellness__soon">Coming 2026</span>}
              </h3>
              <p class="wellness__copy">{w.copy}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ANIMAL SANCTUARY -->
  <section id="animal-sanctuary" class="section sanctuary">
    <div class="sanctuary__media">
      <Image
        src={photos.butteriFoal}
        alt="A rescued foal in the estate pasture"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        loading="lazy"
      />
      <div class="sanctuary__scrim" aria-hidden="true"></div>
    </div>
    <div class="sanctuary__content wrap wrap--narrow">
      <Reveal as="p" class="eyebrow eyebrow--gold">Animal Sanctuary</Reveal>
      <Reveal as="h2" delay={0.05}>The True Dolce Vita Awaits</Reveal>
      <Reveal delay={0.1}><hr class="rule" /></Reveal>
      <Reveal delay={0.12}>
        <p class="sanctuary__body">
          Part of the estate is dedicated to a small animal sanctuary, where we care for rescued
          animals who now enjoy the peace and freedom of the Tuscan countryside. They are gentle,
          friendly, and very much part of the soul of the villa. Many have come from difficult
          pasts, and Villa Dolce Vita has become their forever home.
        </p>
      </Reveal>
      <Reveal delay={0.15}>
        <ul class="sanctuary__notes">
          {sanctuaryNotes.map((n) => <li>{n}</li>)}
        </ul>
      </Reveal>
      <Reveal delay={0.18}>
        <p class="sanctuary__body">
          By staying at Villa Dolce Vita, you help support their care and give them the peaceful
          life they deserve.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- PRIVATE WORKSHOPS -->
  <section id="workshops" class="section split--stone">
    <div class="wrap">
      <SectionHeader eyebrow="Private Workshops" title="Leave with a New Skill, Not Just a Suntan">
        <p>
          A number of guests use the villa as a private base for hands-on experiences. If you're
          planning a small-group retreat or a milestone celebration, here's what we can build
          around your stay.
        </p>
      </SectionHeader>
      <div class="workshops-grid">
        {
          workshops.map((g) => (
            <article class="workshop" data-reveal>
              <h3 class="workshop__title">{g.title}</h3>
              <ul>{g.items.map((it) => <li>{it}</li>)}</ul>
            </article>
          ))
        }
      </div>
      <div class="center-cta">
        <Button href="/contact" variant="ghost">Plan your experience</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 0.9rem + 1.1vw, 1.75rem);
    line-height: 1.5;
    color: var(--c-forest);
  }

  /* Sticky anchor nav */
  .anchor-nav {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.8rem;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: 1.1rem;
  }
  .anchor-nav a {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color var(--dur-fast);
  }
  .anchor-nav a:hover {
    color: var(--accent-deep);
  }

  /* Day trips */
  .daytrip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .daytrip__media {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    margin-bottom: 1.2rem;
  }
  .daytrip__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .daytrip__title {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .daytrip__copy {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* Cities */
  .cities {
    display: grid;
    gap: 2.5rem;
  }
  .city {
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }
  .city__name {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
  }
  .city__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .city__label {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.6rem;
  }
  .city__cols ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.35rem;
  }
  .city__cols li {
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  /* Transfers + tours */
  .tours {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .rate-table {
    width: 100%;
    border-collapse: collapse;
  }
  .rate-table th,
  .rate-table td {
    text-align: left;
    padding: 0.85rem 0.5rem;
    border-bottom: 1px solid var(--line);
    font-size: 0.95rem;
  }
  .rate-table th {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    font-size: var(--fs-eyebrow);
    color: var(--accent-deep);
  }
  .rate-table td:last-child,
  .rate-table th:last-child {
    text-align: right;
    white-space: nowrap;
  }
  .fineprint,
  .tour__dur {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-style: italic;
    margin-top: 1rem;
  }
  .tour-list {
    display: grid;
    gap: 1.5rem;
  }
  .tour {
    padding: 1.5rem 1.7rem;
  }
  .tour__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .tour__head h3 {
    font-size: 1.25rem;
  }
  .tour__price {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--accent-deep);
    white-space: nowrap;
  }
  .tour__dur {
    margin-top: 0.2rem;
  }
  .tour ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 0.4rem;
  }
  .tour li {
    color: var(--text-muted);
    font-size: 0.9rem;
    padding-left: 1.2rem;
    position: relative;
  }
  .tour li::before {
    content: "·";
    position: absolute;
    left: 0.3rem;
    color: var(--accent-deep);
  }

  /* Wellness */
  .wellness-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .wellness {
    background: var(--c-ivory);
    padding: clamp(1.8rem, 3vw, 2.6rem);
  }
  .wellness__title {
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .wellness__soon {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--accent);
    color: var(--c-forest);
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-sm);
  }
  .wellness__copy {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* Sanctuary — full-bleed dark */
  .sanctuary {
    position: relative;
    color: var(--c-ivory);
    display: flex;
    align-items: center;
    min-height: 80svh;
    overflow: hidden;
  }
  .sanctuary__media {
    position: absolute;
    inset: 0;
  }
  .sanctuary__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sanctuary__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(47, 63, 53, 0.85) 0%,
      rgba(47, 63, 53, 0.55) 60%,
      rgba(47, 63, 53, 0.25) 100%
    );
  }
  .sanctuary__content {
    position: relative;
    z-index: 2;
  }
  .sanctuary__body {
    color: var(--text-on-dark-muted);
  }
  .sanctuary__notes {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: grid;
    gap: 0.7rem;
  }
  .sanctuary__notes li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--c-ivory);
  }
  .sanctuary__notes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border: 1px solid var(--accent);
    transform: rotate(45deg);
  }

  /* Workshops */
  .workshops-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .workshop {
    border-top: 2px solid var(--accent-deep);
    padding-top: 1.4rem;
  }
  .workshop__title {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }
  .workshop ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }
  .workshop li {
    color: var(--text-muted);
    font-size: 0.93rem;
  }
  .center-cta {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  @media (max-width: 1080px) {
    .daytrip-grid,
    .wellness-grid,
    .workshops-grid,
    .city__cols {
      grid-template-columns: repeat(2, 1fr);
    }
    .tours {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 620px) {
    .daytrip-grid,
    .wellness-grid,
    .workshops-grid,
    .city__cols {
      grid-template-columns: 1fr;
    }
  }
</style>
